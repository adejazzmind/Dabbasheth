@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="mb-4">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4.5rem;"></i>
            </div>
            <h1 class="text-danger fw-bold">Something Went Wrong</h1>
            <p class="lead text-muted">We encountered an unexpected error.</p>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            <a href="/" class="btn btn-primary btn-lg px-5">Return to Home</a>
        </div>
    </div>
</div>
@model ErrorViewModel
@{
    ViewData["Title"] = "Transaction Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            
            <div class="mb-4">
                <i class="bi bi-exclamation-octagon-fill text-danger" style="font-size: 4rem;"></i>
            </div>

            <h1 class="text-danger font-weight-bold">Oops! Something went wrong</h1>
            <p class="lead text-muted">We encountered an issue while processing your transaction with Paystack.</p>

            <div class="card bg-light border-0 p-4 mb-4" style="border-radius: 15px;">
                <p class="mb-2"><strong>Possible Reasons:</strong></p>
                <ul class="text-left d-inline-block small">
                    <li>Your Paystack <strong>Secret Key</strong> might be invalid or missing.</li>
                    <li>There is a temporary issue with your <strong>internet connection</strong>.</li>
                    <li>The payment session has timed out.</li>
                </ul>
            </div>

            @if (Model?.ShowRequestId == true)
            {
                <p class="small text-muted">
                    <strong>Reference ID:</strong> <code>@Model.RequestId</code>
                </p>
            }

            <div class="mt-4">
                <a href="/" class="btn btn-primary btn-lg px-5 shadow-sm" style="border-radius: 10px;">
                    Return to Dashboard
                </a>
            </div>

            <p class="mt-4 extra-small text-muted">
                If this persists, please verify your keys in <code>appsettings.json</code>.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}
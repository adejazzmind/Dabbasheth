@{
    ViewData["Title"] = "Payment Successful";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 6rem;"></i>
            </div>

            <h2 class="fw-bold text-success mb-3">Payment Successful!</h2>
            <p class="lead text-muted mb-4">@ViewBag.Message</p>

            <div class="card bg-light border-0 p-4 mb-4" style="border-radius: 20px;">
                <p class="mb-1 small text-uppercase text-muted">Transaction Type</p>
                <p class="h5 fw-bold text-success">Wallet Top-up</p>
            </div>

            <a href="@Url.Action("Index", "Home")"
                   class="btn btn-success btn-lg shadow-sm py-3 rounded-pill fw-bold">
                ← Back to Dashboard
            </a>
        </div>
    </div>
</div>
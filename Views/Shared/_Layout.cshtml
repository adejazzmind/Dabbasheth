<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    @* ✅ NATIVE APP VIEWPORT - Prevents zooming, handles phone notches, and enables app-like scaling *@
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="theme-color" content="#014134">
    <title>@ViewData["Title"] - IES Urban Hub</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Dabbasheth.styles.css" asp-append-version="true" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        :root {
        --urban-emerald: #014134;
        --urban-gold: #D4AF37;
        }

        /* 📱 NATIVE APP STRUCTURE */
        body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        margin: 0;
        background-color: #fbfbfb;
        -webkit-tap-highlight-color: transparent; /* Removes blue flash on mobile taps */
        }

        main {
        flex: 1 0 auto;
        }

        /* Hide Scrollbar for App-like Feel */
        ::-webkit-scrollbar {
        display: none;
        }

        /* 📱 MOBILE BOTTOM NAV STYLING */
        .mobile-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: #ffffff;
        display: flex;
        justify-content: space-around;
        align-items: center;
        border-top: 1px solid rgba(0,0,0,0.05);
        z-index: 1050;
        box-shadow: 0 -5px 15px rgba(0,0,0,0.03);
        padding-bottom: env(safe-area-inset-bottom); /* Fix for iPhone Notch */
        }

        .mobile-nav .nav-item {
        text-decoration: none;
        color: #8e8e93;
        display: flex;
        flex-direction: column;
        align-items: center;
        font-size: 11px;
        font-weight: 500;
        transition: 0.2s;
        }

        .mobile-nav .nav-item i {
        font-size: 22px;
        margin-bottom: 2px;
        }

        /* Active State Logic */
        .mobile-nav .nav-item.active {
        color: var(--urban-emerald) !important;
        }
        
        .mobile-nav .nav-item.active i {
        color: var(--urban-emerald);
        transform: translateY(-2px);
        }

        .main-footer {
        flex-shrink: 0;
        background-color: #ffffff;
        border-top: 1px solid rgba(0,0,0,0.05);
        padding: 40px 0;
        margin-bottom: 80px; /* Space for the floating bottom nav */
        }

        .text-gold {
        color: var(--urban-gold) !important;
        }
    </style>
</head>
<body>

    <main role="main">
        @RenderBody()
        @* Prevents content from being hidden behind the bottom nav *@
        <div class="footer-spacer d-md-none" style="height: 90px;"></div>
    </main>

    @* --- 📱 NATIVE MOBILE BOTTOM NAV --- *@
    <div class="mobile-nav d-md-none">
        <a href="/Home/Index" class="nav-item">
            <i class="bi bi-house-door"></i>
            <span>Home</span>
        </a>
        <a href="/Thrift/Index" class="nav-item">
            <i class="bi bi-piggy-bank"></i>
            <span>Ajo</span>
        </a>
        <a href="/Wallet/Transactions" class="nav-item">
            <i class="bi bi-arrow-left-right"></i>
            <span>History</span>
        </a>
        <a href="/Admin/Index" class="nav-item">
            <i class="bi bi-shield-lock"></i>
            <span>Admin</span>
        </a>
    </div>

    <footer class="main-footer">
        <div class="container text-center">
            <p class="mb-1 fw-bold text-dark" style="letter-spacing: 1px;">IES URBAN HUB</p>
            <p class="mb-0 small text-muted">Powered by Dabbasheth &copy; 2026</p>
            <div class="mt-2">
                <small class="text-gold fw-bold" style="font-size: 0.65rem;">PREMIUM SECURE BANKING</small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
        // Intelligent Active Tab Highlighter for the Bottom Nav
        const path = window.location.pathname.toLowerCase();
            
        $('.mobile-nav .nav-item').each(function() {
        const href = $(this).attr('href').toLowerCase();
                
        // Active detection (including default route)
        if (path === href || (path === "/" && href === "/home/index")) {
        $(this).addClass('active');
        } else {
        $(this).removeClass('active');
        }
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
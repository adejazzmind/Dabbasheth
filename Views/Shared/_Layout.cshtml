<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    @* --- Updated Theme Color for Mobile Browser Bars --- *@
    <meta name="theme-color" content="#0D2149">
    <title>@ViewData["Title"] - IES Urban Hub</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* --- CORE LAYOUT OVERRIDES (Matching v9.0) --- */
        :root {
            --brand-navy: #0D2149;
            --brand-sky: #1A73E8;
            --brand-gold: #FFB800;
            --app-bg: #F0F4F8;
        }

        body { 
            background-color: var(--app-bg); 
            font-family: 'Poppins', sans-serif; 
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        /* 🖥️ SIDEBAR RE-TRANSFORMATION (KILL THE GREEN) */
        #sidebar-wrapper { 
            width: 280px; 
            background: var(--brand-navy) !important; 
            min-height: 100vh; 
            position: sticky; 
            top: 0; 
            transition: all 0.3s;
            z-index: 1000;
            border-right: 1px solid rgba(255,255,255,0.05);
        }

        #page-content-wrapper { 
            flex: 1; 
            overflow-x: hidden; 
            min-height: 100vh; 
            display: flex; 
            flex-direction: column; 
        }

        /* 📱 MOBILE NAVIGATION POLISH */
        .mobile-nav {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            height: 75px;
            background: #ffffff;
            display: flex;
            justify-content: space-around;
            align-items: center;
            z-index: 1050;
            box-shadow: 0 -10px 30px rgba(13, 33, 73, 0.08);
            padding-bottom: env(safe-area-inset-bottom);
        }

        .mobile-nav .nav-item {
            text-decoration: none;
            color: #A3AED0;
            display: flex;
            flex-direction: column;
            align-items: center;
            font-size: 10px;
            font-weight: 600;
        }

        .mobile-nav .nav-item i { font-size: 24px; margin-bottom: 2px; }
        .mobile-nav .nav-item.active { color: var(--brand-sky) !important; }

        ::-webkit-scrollbar { display: none; }
    </style>
</head>
<body>
    @{
        var userRole = TempData.Peek("UserRole")?.ToString();
        var isLoggedIn = !string.IsNullOrEmpty(userRole);
        var wrapperClass = isLoggedIn ? "d-flex" : "";
    }

    <div class="@wrapperClass" id="wrapper">
        
        @* --- 🖥️ SIDEBAR: Only visible if LOGGED IN as ADMIN --- *@
        @if (isLoggedIn && userRole == "Admin")
        {
            <aside class="text-white shadow-lg d-none d-lg-block sidebar" id="sidebar-wrapper">
                <div class="p-4 text-center">
                    <h4 class="fw-bold mb-0" style="color: var(--brand-gold);">IES HUB</h4>
                    <small class="opacity-50 text-uppercase" style="font-size: 0.6rem; letter-spacing: 1px;">Executive Command</small>
                </div>
                
                <div class="list-group list-group-flush px-3 mt-3">
                    <a href="/Admin/Index" class="nav-link active-dashboard">
                        <i class="bi bi-grid-1x2-fill me-3"></i> Dashboard
                    </a>
                    <a href="/Admin/UserManagement" class="nav-link active-customers">
                        <i class="bi bi-people-fill me-3"></i> Customers
                    </a>
                    <a href="/Admin/PayoutControl" class="nav-link active-payouts">
                        <i class="bi bi-wallet2 me-3"></i> Payouts
                    </a>
                    <a href="/Admin/AjoManagement" class="nav-link active-ajo">
                        <i class="bi bi-diagram-3-fill me-3"></i> Ajo Engine
                    </a>
                    <a href="/Admin/SupportCenter" class="nav-link active-help">
                        <i class="bi bi-headset me-3"></i> Help Desk
                    </a>
                    
                    <a href="/Account/Logout" class="nav-link text-danger mt-5">
                        <i class="bi bi-box-arrow-left me-3"></i> Secure Logout
                    </a>
                </div>
            </aside>
        }

        @* 🚀 MAIN CONTENT AREA *@
        <div id="page-content-wrapper">
            <main role="main">
                @RenderBody()
            </main>

            @if (isLoggedIn)
            {
                <footer class="py-4 mt-auto border-top bg-white">
                    <div class="container text-center">
                        <p class="mb-1 fw-bold text-dark">IES URBAN HUB</p>
                        <p class="mb-0 small text-muted">Powered by Dabbasheth &copy; 2026</p>
                        <div class="mt-2 fw-bold" style="font-size: 0.65rem; color: var(--brand-gold);">PREMIUM SECURE BANKING</div>
                    </div>
                </footer>
            }
        </div>
    </div>

    @* --- 📱 MOBILE NAV --- *@
    @if (isLoggedIn)
    {
        <div class="mobile-nav d-lg-none">
            @if (userRole == "Admin")
            {
                <a href="/Admin/Index" class="nav-item"><i class="bi bi-speedometer2"></i><span>Stats</span></a>
                <a href="/Admin/UserManagement" class="nav-item"><i class="bi bi-people-fill"></i><span>Users</span></a>
                <a href="/Admin/PayoutControl" class="nav-item"><i class="bi bi-cash-stack"></i><span>Payouts</span></a>
                <a href="/Admin/SupportCenter" class="nav-item"><i class="bi bi-headset"></i><span>Help</span></a>
            }
            else
            {
                <a href="/Home/Index" class="nav-item"><i class="bi bi-house-door"></i><span>Home</span></a>
                <a href="/Home/Thrift" class="nav-item"><i class="bi bi-piggy-bank"></i><span>Savings</span></a>
                <a href="/Home/Rewards" class="nav-item"><i class="bi bi-gift"></i><span>Rewards</span></a>
                <a href="/Home/Profile" class="nav-item"><i class="bi bi-person-circle"></i><span>Account</span></a>
            }
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        $(document).ready(function() {
            const path = window.location.pathname.toLowerCase();
            
            // Auto-Highlight Active State
            $('.nav-link, .nav-item').each(function() {
                const href = $(this).attr('href')?.toLowerCase();
                if (href && (path === href || (href !== "/" && path.startsWith(href)))) {
                    $(this).addClass('active');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
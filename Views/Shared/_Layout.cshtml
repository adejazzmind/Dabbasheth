<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IES Life Hub (Dabbasheth)</title>
    
    <!-- Styles -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Dabbasheth.styles.css" asp-append-version="true" />

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- HEADER -->
    <header class="sticky-top shadow-sm bg-white">
        <nav class="navbar navbar-expand-lg py-3">
            <div class="container">
                <!-- Branding -->
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-2 shadow-sm"
                         style="width: 40px; height: 40px; background: rgba(0, 208, 156, 0.2);">
                        <i class="bi bi-briefcase-fill text-success"></i>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="brand-text" style="letter-spacing: -1px; font-size: 1.4rem; line-height: 1;">IES Life Hub</span>
                        <small class="text-muted fw-bold" style="font-size: 0.6rem; letter-spacing: 0.5px;">DABBASHETH | GENERAL MERCHANDISE</small>
                    </div>
                </a>

                <!-- Mobile Toggle -->
                <button class="navbar-toggler border-0 shadow-none" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navbar Content -->
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between" id="mainNavbar">
                    <ul class="navbar-nav flex-grow-1">
                        @if (TempData.Peek("UserEmail") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 fw-bold" asp-controller="Home" asp-action="Index">Dashboard</a>
                            </li>

                            @if (TempData.Peek("UserRole")?.ToString() == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-bold px-3 d-flex align-items-center"
                                           asp-controller="Admin" asp-action="Index">
                                        <i class="bi bi-shield-lock-fill me-1"></i> Admin Hub
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <!-- User Actions -->
                    <div class="d-flex align-items-center gap-3">
                        @if (TempData.Peek("UserEmail") != null)
                        {
                            <span class="text-muted small d-none d-lg-inline">
                                Welcome, <b>@(TempData.Peek("UserName") ?? "User")</b>
                            </span>
                            <a asp-controller="Account" asp-action="Logout"
                                   class="btn btn-outline-danger rounded-pill px-3 fw-bold">
                                <i class="bi bi-power me-1"></i>Logout
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login"
                               class="btn btn-outline-primary rounded-pill px-4 fw-bold">Login</a>
                            
                            <a asp-controller="Account" asp-action="Register"
                                   class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm text-white"
                                   style="background-color: #00D09C !important; border: none !important;">
                                Join Hub
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer text-muted py-4 border-top bg-light mt-auto">
        <div class="container text-center">
            <small class="fw-bold">&copy; 2026 - IES Life Hub (Dabbasheth)</small>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
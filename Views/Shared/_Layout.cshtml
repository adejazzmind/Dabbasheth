<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    @* --- 📱 MOBILE VIEWPORT & APP OVERRIDES --- *@
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    
    @* --- 🎨 THEME COLOR: Matches your new Premium Navy --- *@
    <meta name="theme-color" content="#050B18">
    
    <title>@ViewData["Title"] - IES Urban Hub</title>
    
    @* --- External Assets --- *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --navy-deep: #050B18;
            --blue-light: #00B4D8;
            --gold: #D4AF37;
            --white: #FFFFFF;
        }

        /* --- GLOBAL APP FEEL --- */
        body { 
            background-color: var(--navy-deep) !important; 
            font-family: 'Inter', sans-serif; 
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        /* --- DESKTOP SIDEBAR (Admin Only) --- */
        #sidebar-wrapper { 
            width: 280px; 
            background: #0A192F !important; 
            min-height: 100vh; 
            position: sticky; 
            top: 0; 
            border-right: 1px solid rgba(0, 180, 216, 0.1);
        }

        /* --- CUSTOMER MOBILE BOTTOM NAV --- */
        .mobile-nav {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            height: 70px;
            background: rgba(10, 25, 47, 0.95);
            backdrop-filter: blur(20px);
            display: flex;
            justify-content: space-around;
            align-items: center;
            z-index: 2000;
            border-top: 1px solid rgba(0, 180, 216, 0.1);
            padding-bottom: env(safe-area-inset-bottom);
        }

        .mobile-nav .nav-item {
            text-decoration: none;
            color: rgba(255, 255, 255, 0.5);
            display: flex;
            flex-direction: column;
            align-items: center;
            font-size: 10px;
            font-weight: 500;
            transition: 0.3s;
        }

        .mobile-nav .nav-item i { font-size: 22px; margin-bottom: 2px; }
        .mobile-nav .nav-item.active { color: var(--gold) !important; }
        .mobile-nav .nav-item.active i { transform: scale(1.1); color: var(--gold); }

        #wrapper { display: flex; width: 100%; }
        #page-content-wrapper { flex: 1; min-height: 100vh; }

        ::-webkit-scrollbar { display: none; }
    </style>
</head>
<body>
    @{
        var userRole = TempData.Peek("UserRole")?.ToString();
        var isLoggedIn = !string.IsNullOrEmpty(userRole);
    }

    <div id="wrapper">
        @* --- 🖥️ SIDEBAR: ADMIN ONLY --- *@
        @if (isLoggedIn && userRole == "Admin")
        {
            <aside class="sidebar d-none d-lg-block" id="sidebar-wrapper">
                <div class="p-4 text-center">
                    <h4 class="fw-bold text-gold mb-0">IES HUB</h4>
                    <small class="text-white opacity-50 x-small tracking-widest">EXECUTIVE</small>
                </div>
                
                <div class="list-group list-group-flush px-3 mt-4">
                    <a href="/Admin/Index" class="nav-link text-white py-3"><i class="bi bi-speedometer2 me-3"></i> Dashboard</a>
                    <a href="/Admin/UserManagement" class="nav-link text-white py-3"><i class="bi bi-people me-3"></i> Customers</a>
                    <a href="/Admin/PayoutControl" class="nav-link text-white py-3"><i class="bi bi-cash-stack me-3"></i> Payouts</a>
                    <a href="/Admin/AjoManagement" class="nav-link text-white py-3"><i class="bi bi-diagram-3 me-3"></i> Ajo Engine</a>
                    <a href="/Account/Logout" class="nav-link text-danger mt-5"><i class="bi bi-power me-3"></i> Logout</a>
                </div>
            </aside>
        }

        @* 🚀 MAIN CONTENT AREA *@
        <div id="page-content-wrapper">
            <main role="main">
                @RenderBody()
            </main>

            @* Only show the footer for Admins or on Desktop to keep mobile clean *@
            @if (isLoggedIn && (userRole == "Admin" || Context.Request.Headers["User-Agent"].ToString().Contains("Windows")))
            {
                <footer class="py-4 mt-5 text-center opacity-25">
                    <p class="mb-0 x-small text-white">IES URBAN HUB &bull; Powered by Dabbasheth &copy; 2026</p>
                </footer>
            }
        </div>
    </div>

    @* --- 📱 MOBILE BOTTOM BAR: CLEAN & LUXE --- *@
    @if (isLoggedIn)
    {
        <div class="mobile-nav d-lg-none">
            @if (userRole == "Admin")
            {
                <a href="/Admin/Index" class="nav-item"><i class="bi bi-grid-fill"></i><span>Stats</span></a>
                <a href="/Admin/UserManagement" class="nav-item"><i class="bi bi-people-fill"></i><span>Users</span></a>
                <a href="/Admin/PayoutControl" class="nav-item"><i class="bi bi-wallet2"></i><span>Payouts</span></a>
                <a href="/Account/Logout" class="nav-item"><i class="bi bi-door-open"></i><span>Exit</span></a>
            }
            else
            {
                <a href="/Home/Index" class="nav-item"><i class="bi bi-house-fill"></i><span>Home</span></a>
                <a href="/Home/Thrift" class="nav-item"><i class="bi bi-piggy-bank-fill"></i><span>Savings</span></a>
                <a href="/Home/Rewards" class="nav-item"><i class="bi bi-stars"></i><span>Win</span></a>
                <a href="/Home/Profile" class="nav-item"><i class="bi bi-person-fill"></i><span>Me</span></a>
            }
        </div>
    }

    @* --- Scripts --- *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        $(document).ready(function() {
            const path = window.location.pathname.toLowerCase();
            $('.nav-link, .nav-item').each(function() {
                const href = $(this).attr('href')?.toLowerCase();
                if (href && (path === href || (href !== "/" && path.startsWith(href)))) {
                    $(this).addClass('active');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
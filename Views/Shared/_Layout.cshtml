<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    @* ✅ NATIVE APP VIEWPORT - Prevents zooming and enables app-like scaling *@
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>@ViewData["Title"] - IES Urban Hub</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Dabbasheth.styles.css" asp-append-version="true" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        :root {
        --urban-emerald: #014134;
        --urban-gold: #D4AF37;
        }

        /* 💡 NATIVE APP STRUCTURE */
        body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        margin: 0;
        background-color: #fbfbfb;
        /* Prevents the 'gray flash' on taps on mobile */
        -webkit-tap-highlight-color: transparent;
        }

        main {
        flex: 1 0 auto;
        /* Ensures content starts below the fixed header if one exists */
        }

        /* Hidden scrollbar but keep functionality */
        ::-webkit-scrollbar {
        display: none;
        }

        .main-footer {
        flex-shrink: 0;
        background-color: #ffffff;
        border-top: 1px solid rgba(0,0,0,0.05);
        padding: 40px 0;
        /* Bottom margin accommodates the floating mobile nav */
        margin-bottom: 100px;
        }

        /* Bottom Nav Active State Logic */
        .mobile-nav a.active {
        color: var(--urban-gold) !important;
        transform: translateY(-2px);
        }
    </style>
</head>
<body>

    <main role="main">
        @RenderBody()
        
        @* Dynamic spacer to prevent the floating Nav from covering the last content *@
        <div class="footer-spacer" style="height: 120px;"></div>
    </main>

    <footer class="main-footer">
        <div class="container text-center">
            <p class="mb-1 fw-bold text-dark" style="letter-spacing: 1px;">IES URBAN HUB</p>
            <p class="mb-0 small text-muted">Powered by Dabbasheth &copy; 2026</p>
            <div class="mt-2">
                <small class="text-gold fw-bold" style="font-size: 0.65rem;">PREMIUM SECURE BANKING</small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
        // Intelligent Active Tab Highlighter
        const path = window.location.pathname.toLowerCase();
            
        $('.mobile-nav a, .opay-bottom-nav a').each(function() {
        const href = $(this).attr('href').toLowerCase();
                
        // Match current path to Nav link
        if (path === href || (path === "/" && href === "/home/index")) {
        $(this).addClass('active text-gold').removeClass('text-muted');
        } else {
        $(this).removeClass('active text-gold').addClass('text-muted');
        }
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
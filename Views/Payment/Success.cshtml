@{
    Layout = "_Layout"; ViewData["Title"] = "Payment Successful";
}

<div class="container mt-5 py-4">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-4 shadow"
                 style="width:100px;height:100px;background:#e8f5e9;">
                <i class="bi bi-check-circle-fill text-success" style="font-size:3.5rem;"></i>
            </div>
            <h2 class="fw-bold text-success mb-2">Payment Successful!</h2>
            <p class="text-muted lead mb-4">@ViewBag.Message</p>

            <div class="card bg-light border-0 rounded-4 p-4 mb-4">
                <p class="mb-1 small text-uppercase text-muted fw-bold">Transaction Type</p>
                <p class="h5 fw-bold text-success mb-0">Wallet Top-up</p>
            </div>

            <a href="@Url.Action("Index", "Home")"
                   class="btn w-100 rounded-pill py-3 fw-bold text-white"
                   style="background:linear-gradient(135deg,#1A73E8,#00B4DB);">
                ← Back to Dashboard
            </a>
        </div>
    </div>
</div>

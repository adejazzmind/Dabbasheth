@{
    Layout = "_Layout"; ViewData["Title"] = "Support Chat";
    var messages  = ViewBag.Messages  as List<Dabbasheth.Models.ChatMessage>;
    var userEmail = ViewBag.UserEmail  as string ?? "";
}
<style>
.chat-wrap{display:flex;flex-direction:column;height:calc(100vh - 130px);max-width:700px;margin:0 auto;padding:16px}
.chat-header{background:linear-gradient(135deg,#0A0F1E,#1A73E8);border-radius:20px;padding:18px 20px;display:flex;align-items:center;gap:14px;margin-bottom:12px;color:#fff}
.chat-body{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:10px;padding:4px 0}
.chat-footer{background:#fff;border-radius:18px;padding:14px 16px;border:1px solid #E2E8F0;margin-top:10px;display:flex;gap:10px;align-items:flex-end}
.msg{max-width:74%;padding:11px 16px;border-radius:18px;font-size:.875rem;line-height:1.5;word-break:break-word}
.msg.mine{background:linear-gradient(135deg,#1A73E8,#0EA5E9);color:#fff;border-radius:18px 18px 4px 18px;align-self:flex-end}
.msg.theirs{background:#F1F5F9;color:#0F172A;border-radius:18px 18px 18px 4px;align-self:flex-start}
.msg-wrap{display:flex;flex-direction:column}
.msg-wrap.mine{align-items:flex-end}
.msg-wrap.theirs{align-items:flex-start}
.msg-label{font-size:.65rem;color:#94A3B8;margin-bottom:3px;font-weight:600}
.msg-time{font-size:.65rem;opacity:.6;margin-top:3px}
.chat-input{flex:1;border:1.5px solid #E2E8F0;border-radius:14px;padding:12px 16px;font-size:.875rem;font-family:'Inter',sans-serif;outline:none;resize:none;min-height:46px;max-height:120px;transition:.2s;background:#F8FAFC}
.chat-input:focus{border-color:#1A73E8;background:#fff;box-shadow:0 0 0 3px rgba(26,115,232,.1)}
.send-btn{background:linear-gradient(135deg,#1A73E8,#0EA5E9);color:#fff;border:none;border-radius:14px;padding:12px 18px;font-size:1.1rem;cursor:pointer;flex-shrink:0;transition:.2s}
.send-btn:hover{transform:scale(1.05)}
</style>

<div class="chat-wrap">
    <div class="chat-header">
        <div style="width:44px;height:44px;background:rgba(255,255,255,.15);border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <i class="bi bi-headset" style="font-size:1.3rem"></i>
        </div>
        <div>
            <div style="font-weight:700;font-size:.95rem">IES Support Team</div>
            <div style="font-size:.75rem;opacity:.7">We typically reply within minutes</div>
        </div>
        <div style="margin-left:auto;width:10px;height:10px;background:#10B981;border-radius:99px;box-shadow:0 0 8px #10B981"></div>
    </div>

    <div class="chat-body" id="chatBody">
        @if(messages == null || !messages.Any()){
            <div style="text-align:center;padding:50px 20px">
                <div style="width:72px;height:72px;background:linear-gradient(135deg,#EFF6FF,#DBEAFE);border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
                    <i class="bi bi-chat-dots-fill" style="font-size:1.8rem;color:#1A73E8"></i>
                </div>
                <h6 style="font-weight:700;color:#0F172A;margin-bottom:6px">Hi there! 👋</h6>
                <p style="color:#64748B;font-size:.85rem;margin:0">Send us a message and we'll respond as soon as possible.</p>
            </div>
        }
        @if(messages != null){
            @foreach(var m in messages){
                var isMine = !m.IsAdminMessage;
                <div class="msg-wrap @(isMine?"mine":"theirs")">
                    @if(!isMine){ <div class="msg-label">IES Support</div> }
                    <div class="msg @(isMine?"mine":"theirs")">@m.Message</div>
                    <div class="msg-time">@m.SentAt.ToLocalTime().ToString("HH:mm")</div>
                </div>
            }
        }
    </div>

    <div class="chat-footer">
        <form asp-action="SendMessage" asp-controller="Home" method="post" style="display:flex;gap:10px;flex:1;align-items:flex-end">
            @Html.AntiForgeryToken()
            <textarea name="message" class="chat-input" placeholder="Type your message…" rows="1" required
                      onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();this.form.submit()}"></textarea>
            <button type="submit" class="send-btn"><i class="bi bi-send-fill"></i></button>
        </form>
    </div>
</div>
<script>const cb=document.getElementById('chatBody');if(cb)cb.scrollTop=cb.scrollHeight;</script>

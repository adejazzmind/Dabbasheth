@{
    ViewData["Title"] = "Loan Hub";
}

<div class="container mt-5" style="padding-bottom: 120px;">
    <div class="row justify-content-center text-center mb-5">
        <div class="col-md-8">
            <h2 class="fw-bold">Instant Credit Hub</h2>
            <p class="text-muted">No collateral, no paperwork. Just quick cash.</p>
        </div>
    </div>

    <div class="row g-4">
        @* Nano Loan *@
        <div class="col-md-6">
            <div class="card card-dab border-0 shadow-sm p-4 h-100">
                <h4 class="fw-bold text-primary">Nano Loan</h4>
                <p class="small text-muted">Up to ₦50,000 for quick needs.</p>
                <ul class="list-unstyled mb-4 small">
                    <li><i class="bi bi-check-circle text-success me-2"></i> 15% Interest Rate</li>
                    <li><i class="bi bi-check-circle text-success me-2"></i> 30 Days Duration</li>
                </ul>
                <form asp-action="ProcessLoan" method="post">
                    <input type="hidden" name="loanAmount" value="50000" />
                    <button type="submit" class="btn btn-outline-primary w-100 rounded-pill fw-bold">Apply Now</button>
                </form>
            </div>
        </div>

        @* Business Expansion *@
        <div class="col-md-6">
            <div class="card card-dab border-0 shadow-sm p-4 h-100 bg-soft-primary">
                <h4 class="fw-bold">Business Growth</h4>
                <p class="small text-muted">Up to ₦500,000 for entrepreneurs.</p>
                <ul class="list-unstyled mb-4 small">
                    <li><i class="bi bi-check-circle text-success me-2"></i> 10% Interest Rate</li>
                    <li><i class="bi bi-check-circle text-success me-2"></i> 6 Months Duration</li>
                </ul>
                <button class="btn btn-primary w-100 rounded-pill fw-bold" disabled>Boost My Business</button>
                <small class="text-muted d-block mt-2">Requirement: 3 months active savings</small>
            </div>
        </div>
    </div>
</div>
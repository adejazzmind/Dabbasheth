@{
    Layout = "_Layout";
    ViewData["Title"] = "Withdraw Funds";
    decimal balance = ViewBag.Balance ?? 0m;
}

<div class="container py-4 animate__animated animate__fadeInUp" style="padding-bottom:90px!important;">
    <div class="d-flex align-items-center mb-4">
        <a href="/Home/Index" class="text-dark me-3 fs-4 text-decoration-none"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-bold mb-0">Withdraw Funds</h5>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 text-center bg-white">
        <small class="text-muted text-uppercase fw-bold" style="font-size:0.65rem;letter-spacing:1px;">Available Balance</small>
        <h2 class="fw-bold mt-1 text-success">₦@balance.ToString("N2")</h2>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <form asp-action="SubmitWithdrawal" asp-controller="Home" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">Destination Bank</label>
                <select name="bankName" class="form-select border-0 bg-light py-3 rounded-4" required>
                    <option value="" disabled selected>Select bank…</option>
                    @foreach (var bank in new[] { "Access Bank", "GTBank", "Zenith Bank", "OPay", "Kuda Bank", "PalmPay", "UBA", "First Bank", "Wema Bank" })
                    {
                        <option value="@bank">@bank</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">Account Number</label>
                <input type="number" name="accountNumber" class="form-control border-0 bg-light py-3 rounded-4"
                       placeholder="10-digit account number" maxlength="10" required />
            </div>
            <div class="mb-4">
                <label class="small fw-bold text-muted mb-1">Amount (₦)</label>
                <div class="input-group">
                    <span class="input-group-text border-0 bg-light fw-bold" style="color:#FFB800;">₦</span>
                    <input type="number" name="amount" class="form-control border-0 bg-light py-3 fw-bold rounded-end-4"
                           placeholder="Min: ₦500" min="500" max="@balance" required />
                </div>
            </div>
            <button type="submit" class="btn w-100 rounded-pill py-3 fw-bold text-white shadow"
                    style="background:linear-gradient(135deg,#1A73E8,#00B4DB);">
                <i class="bi bi-shield-lock-fill me-2"></i>Submit Withdrawal Request
            </button>
        </form>
    </div>

    <div class="mt-3 p-3 rounded-4 d-flex align-items-start"
         style="background:rgba(255,184,0,0.1);border:1px solid rgba(255,184,0,0.3);">
        <i class="bi bi-info-circle-fill me-2 mt-1" style="color:#FFB800;"></i>
        <small>All withdrawal requests require <strong>admin approval</strong>. Funds are released once approved.</small>
    </div>
</div>

@{
    Layout = "_Layout";
    var balance = ViewBag.Balance ?? 0m;
}

@* --- 📱 MOBILE WITHDRAWAL HEADER --- *@
<div class="app-header justify-content-between">
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Index", "Home")" class="text-dark me-3">
            <i class="bi bi-chevron-left h4 mb-0"></i>
        </a>
        <h6 class="mb-0 fw-bold">Withdraw Funds</h6>
    </div>
</div>

<div class="app-content container pb-5 animate__animated animate__fadeInUp">
    
    @* --- 💳 BALANCE SUMMARY --- *@
    <div class="card border-0 shadow-sm rounded-4 p-4 mt-3 bg-white text-center">
        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 1px;">Urban Wallet Balance</small>
        <h2 class="fw-bold text-success mt-1">₦@balance.ToString("N2")</h2>
    </div>

    @* --- 🏦 WITHDRAWAL FORM --- *@
    <div class="mt-4">
        <form asp-action="SubmitWithdrawal" method="post" id="withdrawForm">
            @Html.AntiForgeryToken()
            
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="mb-3">
                    <label class="small fw-bold text-muted mb-2">DESTINATION BANK</label>
                    <select name="bankName" class="form-select border-0 bg-light rounded-3 py-3" required>
                        <option value="" disabled selected>Select a bank</option>
                        <option value="Access Bank">Access Bank</option>
                        <option value="GTBank">GTBank</option>
                        <option value="Zenith Bank">Zenith Bank</option>
                        <option value="Opay">OPay (Digital)</option>
                        <option value="Kuda Bank">Kuda Microfinance</option>
                        <option value="PalmPay">PalmPay</option>
                        <option value="UBA">UBA</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="small fw-bold text-muted mb-2">ACCOUNT NUMBER</label>
                    <input type="number" name="accountNumber" class="form-control border-0 bg-light rounded-3 py-3"
                           placeholder="Enter 10-digit account" required maxlength="10">
                </div>

                <div class="mb-2">
                    <label class="small fw-bold text-muted mb-2">AMOUNT TO CASHOUT</label>
                    <div class="input-group">
                        <span class="input-group-text border-0 bg-light fw-bold text-gold">₦</span>
                        <input type="number" name="amount" class="form-control border-0 bg-light rounded-end-3 py-3 fw-bold"
                               placeholder="Min: ₦500" required>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-gold w-100 rounded-pill py-3 fw-bold shadow-lg">
                    <i class="bi bi-shield-lock-fill me-1"></i> Send Withdrawal Request
                </button>
            </div>
        </form>
    </div>

    @* --- 🛡️ TRUST INDICATOR --- *@
    <div class="mt-4 p-3 rounded-4 bg-soft-gold border border-gold d-flex align-items-start">
        <i class="bi bi-info-circle-fill text-gold me-3 h4"></i>
        <small class="text-dark">
            <strong>Security Notice:</strong> All withdrawal requests go through <strong>CEO Verification</strong>.
            Once approved, funds are released to your bank instantly.
        </small>
    </div>
</div>
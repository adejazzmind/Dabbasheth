@{
    ViewData["Title"] = "Withdraw Funds - IES Life Hub";
    decimal balance = ViewBag.Balance ?? 0.00m;
}

<div class="container mt-5" style="padding-bottom: 120px;">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg p-4 p-md-5" style="border-radius: 30px;">
                
                <div class="text-center mb-4">
                    <div class="bg-soft-danger d-inline-block p-3 rounded-circle mb-3" style="background: rgba(220, 53, 69, 0.1);">
                        <i class="bi bi-bank2 text-danger display-6"></i>
                    </div>
                    <h3 class="fw-bold">Withdraw Funds</h3>
                    <p class="text-muted small">Move money from your IES Hub wallet to your bank.</p>
                </div>

                @* WALLET PREVIEW *@
                <div class="alert bg-light border-0 d-flex justify-content-between align-items-center mb-4" style="border-radius: 15px;">
                    <small class="fw-bold text-muted">AVAILABLE</small>
                    <span class="fw-bold text-dark">₦@balance.ToString("N2")</span>
                </div>

                <form asp-action="ProcessWithdrawal" method="post" id="withdrawForm">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">DESTINATION BANK</label>
                        <select name="bankName" class="form-select bg-light border-0" required style="border-radius: 12px;">
                            <option value="">Select Bank...</option>
                            <option>Access Bank</option>
                            <option>GTBank</option>
                            <option>Zenith Bank</option>
                            <option>Kuda MFB</option>
                            <option>Moniepoint</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">ACCOUNT NUMBER</label>
                        <input type="number" name="accountNumber" class="form-control bg-light border-0" placeholder="0123456789" required style="border-radius: 12px;" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">AMOUNT TO WITHDRAW (₦)</label>
                        <input type="number" name="amount" class="form-control form-control-lg bg-light border-0"
                               max="@balance" placeholder="0.00" required style="border-radius: 12px;" />
                    </div>

                    <button type="button" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold py-3 shadow" onclick="handleTransaction('withdrawForm')">
                        Complete Withdrawal
                    </button>
                </form>

                <div class="text-center mt-4">
                    <small class="text-muted"><i class="bi bi-shield-check me-1"></i> End-to-end encrypted transaction</small>
                </div>
            </div>
        </div>
    </div>
</div>
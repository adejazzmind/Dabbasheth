@{
    Layout = "_Layout"; ViewData["Title"] = "Buy Airtime";
}

<div class="container py-4" style="padding-bottom:90px!important;">
    <div class="d-flex align-items-center mb-4">
        <a href="/Home/Index" class="text-dark me-3 fs-4 text-decoration-none"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-bold mb-0">Buy Airtime</h5>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
        <label class="small fw-bold text-muted mb-3 d-block text-uppercase">Select Network</label>
        <div class="d-flex gap-3 mb-4">
            @foreach (var n in new[] {
                new { Name="MTN",    Color="#FFCC00", Icon="M" },
                new { Name="Airtel", Color="#FF0000", Icon="A" },
                new { Name="Glo",    Color="#00A550", Icon="G" },
                new { Name="9mobile",Color="#006633", Icon="9" }
            })
            {
                <div class="flex-grow-1 text-center p-2 rounded-3 border network-card" style="cursor:pointer;"
                     onclick="selectNetwork(this, '@n.Name')">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold text-white mb-1"
                         style="width:40px;height:40px;background:@n.Color;font-size:0.8rem;">
                        @n.Icon
                    </div>
                    <small class="d-block fw-bold" style="font-size:0.65rem;">@n.Name</small>
                </div>
            }
        </div>

        <form>
            <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">Phone Number</label>
                <input type="tel" class="form-control border-0 bg-light py-3 rounded-4" placeholder="0801 234 5678" />
            </div>
            <div class="mb-4">
                <label class="small fw-bold text-muted mb-1">Amount</label>
                <input type="number" class="form-control border-0 bg-light py-3 rounded-4" placeholder="₦ 0.00" />
                <div class="d-flex gap-2 mt-2 flex-wrap">
                    @foreach (var amt in new[] { "100", "200", "500", "1000" })
                    {
                        <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-3"
                                onclick="document.querySelector('[placeholder=\'₦ 0.00\']').value=@amt">
                            ₦@amt
                        </button>
                    }
                </div>
            </div>
            <button type="submit" class="btn w-100 rounded-pill py-3 fw-bold text-white"
                    style="background:linear-gradient(135deg,#1A73E8,#00B4DB);">
                Purchase Airtime
            </button>
        </form>
    </div>
</div>
<script>
    function selectNetwork(el, name) {
        document.querySelectorAll('.network-card').forEach(c => c.classList.remove('border-primary'));
        el.classList.add('border-primary');
    }
</script>

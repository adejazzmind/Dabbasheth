@{
    Layout = "_Layout";
    ViewData["Title"] = "Me";
}

<div class="p-3" style="background: linear-gradient(to bottom, #00D09C 0%, var(--opay-bg) 100%);">
    <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <img src="https://ui-avatars.com/api/?name=Timi+Sax&background=111C44&color=fff" class="rounded-circle border border-2 border-white" width="60">
            <div class="ms-3">
                <h5 class="fw-bold mb-0">Hi, Timi sax</h5>
                <span class="badge bg-white text-dark rounded-pill small"><i class="bi bi-gem text-primary"></i> Upgrade to Tier 3</span>
            </div>
        </div>
        <i class="bi bi-gear h4 text-white"></i>
    </div>
</div>

<div class="mx-3 p-3 bg-white rounded-4 shadow-sm mb-3">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <small class="text-muted">Total Balance <i class="bi bi-eye-slash"></i></small>
            <h4 class="fw-bold mb-0">****</h4>
            <small class="text-success small">Interest Credited Today ****</small>
        </div>
        <div class="text-success h1"><i class="bi bi-shield-check"></i></div>
    </div>
</div>

<div class="mx-3 mb-3">
    <div class="alert bg-soft-success border-0 d-flex justify-content-between align-items-center rounded-4 p-3">
        <div class="small">
            <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
            <strong>3 Safety Tips</strong><br>Make your account more secure.
        </div>
        <button class="btn btn-success btn-sm rounded-pill px-3">View</button>
    </div>
</div>

<div class="mx-3 bg-white rounded-4 shadow-sm overflow-hidden mb-5">
    <a href="#" class="d-flex align-items-center p-3 text-decoration-none border-bottom">
        <i class="bi bi-list-ul text-success h4 mb-0 me-3"></i>
        <div class="flex-grow-1 text-dark">Transaction History</div>
        <i class="bi bi-chevron-right text-muted"></i>
    </a>
    <a href="#" class="d-flex align-items-center p-3 text-decoration-none border-bottom">
        <i class="bi bi-speedometer2 text-success h4 mb-0 me-3"></i>
        <div class="flex-grow-1 text-dark">Account Limits</div>
        <i class="bi bi-chevron-right text-muted"></i>
    </a>
    <a href="#" class="d-flex align-items-center p-3 text-decoration-none border-bottom">
        <i class="bi bi-credit-card text-success h4 mb-0 me-3"></i>
        <div class="flex-grow-1 text-dark">Bank Card/Account</div>
        <i class="bi bi-chevron-right text-muted"></i>
    </a>
    <a href="@Url.Action("Logout", "Account")" class="d-flex align-items-center p-3 text-decoration-none">
        <i class="bi bi-box-arrow-right text-danger h4 mb-0 me-3"></i>
        <div class="flex-grow-1 text-danger fw-bold">Sign Out</div>
    </a>
</div>
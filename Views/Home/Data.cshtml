@{
    Layout = "_Layout"; ViewData["Title"] = "Buy Data";
}

<div class="container py-4" style="padding-bottom:90px!important;">
    <div class="d-flex align-items-center mb-4">
        <a href="/Home/Index" class="text-dark me-3 fs-4 text-decoration-none"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-bold mb-0">Buy Data Bundle</h5>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <form>
            <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">Phone Number</label>
                <input type="tel" class="form-control border-0 bg-light py-3 rounded-4" placeholder="08012345678" />
            </div>
            <div class="mb-4">
                <label class="small fw-bold text-muted mb-2 d-block">Select Plan</label>
                @foreach (var plan in new[] {
                    new { Size="500MB", Days=14,  Price=300  },
                    new { Size="1.5GB", Days=30,  Price=1000 },
                    new { Size="3GB",   Days=30,  Price=1500 },
                    new { Size="10GB",  Days=30,  Price=3000 }
                })
                {
                    <div class="d-flex justify-content-between align-items-center p-3 rounded-4 border mb-2"
                         style="cursor:pointer;" onclick="selectPlan(this)">
                        <div>
                            <p class="mb-0 fw-bold">@plan.Size / @plan.Days Days</p>
                            <small class="text-muted">Standard Plan</small>
                        </div>
                        <span class="fw-bold text-primary">₦@plan.Price.ToString("N0")</span>
                    </div>
                }
            </div>
            <button type="submit" class="btn w-100 rounded-pill py-3 fw-bold text-white"
                    style="background:linear-gradient(135deg,#1A73E8,#00B4DB);">
                Activate Bundle
            </button>
        </form>
    </div>
</div>
<script>
    function selectPlan(el) {
        document.querySelectorAll('[onclick^="selectPlan"]').forEach(e => e.classList.remove('border-primary'));
        el.classList.add('border-primary');
    }
</script>

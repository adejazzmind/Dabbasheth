@{
    Layout = "_Layout";
    var plans = ViewBag.ThriftPlans as List<Dabbasheth.Models.ThriftPlan>;
}

<div class="app-header justify-content-between">
    <div class="d-flex align-items-center">
        <a href="/Home/Index" class="text-dark me-3"><i class="bi bi-chevron-left h4 mb-0"></i></a>
        <h6 class="mb-0 fw-bold">Target Savings</h6>
    </div>
</div>

<div class="app-content container animate__animated animate__fadeIn">
    
    @* --- 🟢 THRIFT BANNER --- *@
    <div class="premium-card p-4 mb-4 text-white">
        <small class="opacity-75 text-uppercase fw-bold" style="font-size: 0.6rem;">Saving Challenge 2026</small>
        <h3 class="fw-bold">Special Target</h3>
        <p class="small mb-0 opacity-75">Secure your future by setting smart goals today.</p>
    </div>

    @* --- 📝 CREATE GOAL FORM --- *@
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-5">
        <form asp-action="CreateThriftPlan" method="post">
            @Html.AntiForgeryToken()
            
            <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">WHAT ARE YOU SAVING FOR?</label>
                <input type="text" name="title" class="form-control border-0 bg-light py-2" placeholder="e.g. New Laptop, Rent" required />
            </div>

            <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">TARGET AMOUNT (₦)</label>
                <input type="number" name="targetAmount" class="form-control border-0 bg-light py-2" placeholder="Enter amount" required min="1000" />
            </div>

            <div class="mb-4">
                <label class="small fw-bold text-muted mb-1">HOW OFTEN DO YOU WANT TO SAVE?</label>
                
                @* This hidden input holds the actual value for the server *@
                <input type="hidden" name="frequency" id="selectedFrequency" value="Daily" />
                
                <div class="row g-2">
                    <div class="col-3">
                        <button type="button" class="btn btn-outline-success w-100 py-2 small fw-bold freq-btn active" onclick="setFreq('Daily', this)">Daily</button>
                    </div>
                    <div class="col-3">
                        <button type="button" class="btn btn-outline-success w-100 py-2 small fw-bold freq-btn" onclick="setFreq('Weekly', this)">Weekly</button>
                    </div>
                    <div class="col-3">
                        <button type="button" class="btn btn-outline-success w-100 py-2 small fw-bold freq-btn" onclick="setFreq('Monthly', this)">Monthly</button>
                    </div>
                    <div class="col-3">
                        <button type="button" class="btn btn-outline-success w-100 py-2 small fw-bold freq-btn" onclick="setFreq('Yearly', this)">Yearly</button>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-success w-100 rounded-pill py-3 fw-bold shadow">
                Start Savings Goal
            </button>
        </form>
    </div>

    @* --- 📊 ACTIVE GOALS LIST --- *@
    <h6 class="fw-bold mb-3 px-1">Your Active Goals</h6>
    @if (plans != null && plans.Any())
    {
        foreach (var plan in plans)
        {
            var progress = (plan.CurrentSavings / plan.TargetAmount) * 100;
            <div class="card border-0 shadow-sm rounded-4 p-3 mb-3 bg-white">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="fw-bold mb-0">@plan.Title</h6>
                    <span class="badge bg-soft-success text-success">@plan.Status</span>
                </div>
                <div class="progress mb-2" style="height: 6px;">
                    <div class="progress-bar bg-success" style="width: @progress%"></div>
                </div>
                <div class="d-flex justify-content-between small text-muted">
                    <span>₦@plan.CurrentSavings.ToString("N0") saved</span>
                    <span class="fw-bold">₦@plan.TargetAmount.ToString("N0")</span>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-4 opacity-50">
            <i class="bi bi-piggy-bank h1"></i>
            <p class="small">No active goals yet. Start one above!</p>
        </div>
    }
</div>

@* --- 🧠 FREQUENCY LOGIC --- *@
<script>
    function setFreq(val, btn) {
        // Update hidden input
        document.getElementById('selectedFrequency').value = val;
        
        // UI Visual Switch
        document.querySelectorAll('.freq-btn').forEach(b => {
            b.classList.remove('btn-success', 'text-white', 'active');
            b.classList.add('btn-outline-success');
        });
        
        btn.classList.add('btn-success', 'text-white', 'active');
        btn.classList.remove('btn-outline-success');
    }
</script>

<style>
    .bg-soft-success { background: #e8f5e9; }
    .btn-success.active { background-color: #014134 !important; border-color: #014134 !important; }
</style>
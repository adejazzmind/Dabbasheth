@{
    Layout = "_Layout";
    ViewData["Title"] = "Target Savings";
    var plans = ViewBag.ThriftPlans as List<Dabbasheth.Models.ThriftPlan>;
    decimal totalSavings = ViewBag.TotalSavings ?? 0m;
}

<div class="container py-4 animate__animated animate__fadeIn" style="padding-bottom:90px!important;">

    @* ── BANNER ── *@
    <div class="card border-0 shadow rounded-5 text-white p-4 mb-4"
         style="background:linear-gradient(135deg,#1A73E8,#00B4DB);">
        <small class="opacity-75 text-uppercase fw-bold" style="font-size:0.6rem;letter-spacing:2px;">Saving Challenge 2026</small>
        <h3 class="fw-bold mt-1 mb-1">Target Savings</h3>
        <p class="small mb-3 opacity-75">Total saved: ₦@totalSavings.ToString("N0")</p>
    </div>

    @* ── CREATE GOAL ── *@
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
        <h6 class="fw-bold mb-3">Create New Savings Goal</h6>
        <form asp-action="CreateThriftPlan" asp-controller="Home" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">What are you saving for?</label>
                <input type="text" name="title" class="form-control border-0 bg-light py-3 rounded-4"
                       placeholder="e.g. New Laptop, Rent" required />
            </div>
            <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">Target Amount (₦)</label>
                <input type="number" name="targetAmount" class="form-control border-0 bg-light py-3 rounded-4"
                       placeholder="Min. ₦1,000" min="1000" required />
            </div>
            <div class="mb-4">
                <label class="small fw-bold text-muted mb-1">Frequency</label>
                <input type="hidden" name="frequency" id="selectedFrequency" value="Daily" />
                <div class="d-flex gap-2">
                    @foreach (var freq in new[] { "Daily", "Weekly", "Monthly", "Yearly" })
                    {
                        <button type="button"
                                class="btn btn-sm flex-grow-1 rounded-pill fw-bold freq-btn @(freq == "Daily" ? "btn-primary text-white" : "btn-outline-primary")"
                                onclick="setFreq('@freq', this)">
                            @freq
                        </button>
                    }
                </div>
            </div>
            <button type="submit" class="btn w-100 rounded-pill py-3 fw-bold text-white"
                    style="background:linear-gradient(135deg,#1A73E8,#00B4DB);">
                Start Savings Goal
            </button>
        </form>
    </div>

    @* ── ACTIVE GOALS ── *@
    <h6 class="fw-bold mb-3 px-1">Your Active Goals</h6>
    @if (plans != null && plans.Any())
    {
        @foreach (var plan in plans)
        {
            var pct = plan.TargetAmount > 0 ? (plan.CurrentSavings / plan.TargetAmount) * 100 : 0;
            <div class="card border-0 shadow-sm rounded-4 p-3 mb-3 bg-white">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="fw-bold mb-0">@plan.Title</h6>
                    <span class="badge rounded-pill px-2 @(plan.Status == "Completed" ? "bg-success" : "bg-primary")">@plan.Status</span>
                </div>
                <div class="progress mb-2" style="height:6px;border-radius:10px;">
                    <div class="progress-bar" style="width:@pct%;background:linear-gradient(90deg,#1A73E8,#00B4DB);"></div>
                </div>
                <div class="d-flex justify-content-between small text-muted">
                    <span>₦@plan.CurrentSavings.ToString("N0") saved</span>
                    <span class="fw-bold">₦@plan.TargetAmount.ToString("N0")</span>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-4 text-muted opacity-50">
            <i class="bi bi-piggy-bank display-1 d-block mb-2"></i>
            No active goals yet. Create one above!
        </div>
    }
</div>

<script>
    function setFreq(val, btn) {
        document.getElementById('selectedFrequency').value = val;
        document.querySelectorAll('.freq-btn').forEach(b => {
            b.classList.remove('btn-primary', 'text-white');
            b.classList.add('btn-outline-primary');
        });
        btn.classList.add('btn-primary', 'text-white');
        btn.classList.remove('btn-outline-primary');
    }
</script>

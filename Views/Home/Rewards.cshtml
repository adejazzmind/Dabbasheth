@{
    Layout = "_Layout"; ViewData["Title"] = "Rewards Hub"; decimal cashback = ViewBag.Cashback ?? 0.00m;
}

<div class="container py-4" style="padding-bottom:90px!important;">
    <div class="d-flex align-items-center mb-4">
        <a href="/Home/Index" class="text-dark me-3 fs-4 text-decoration-none"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-bold mb-0">Rewards Hub</h5>
    </div>

    <div class="card border-0 shadow rounded-5 text-white p-4 text-center mb-4"
         style="background:linear-gradient(135deg,#1A73E8,#00B4DB);">
        <small class="text-uppercase fw-bold opacity-75" style="letter-spacing:2px;">Total Cashback Earned</small>
        <h1 class="display-4 fw-bold my-3">₦@cashback.ToString("N2")</h1>
        <button class="btn fw-bold rounded-pill px-5 py-2"
                style="background:#FFB800;color:#0D2149;" onclick="claimRewards()">
            Claim to Wallet
        </button>
    </div>

    <div class="row g-3">
        @foreach (var item in new[] {
            new { Icon="bi-piggy-bank",    Color="#e3f0fd", IColor="#1A73E8", Title="Save Daily",   Desc="Earn 1% cashback on every daily thrift contribution." },
            new { Icon="bi-phone-vibrate", Color="#e8f5e9", IColor="#2e7d32", Title="Pay Bills",    Desc="Get ₦50 instant reward when you buy airtime or data." },
            new { Icon="bi-people",        Color="#f3e5f5", IColor="#7b1fa2", Title="Refer & Earn", Desc="Earn ₦500 for every friend who joins and saves." }
        })
        {
            <div class="col-12 col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center bg-white h-100">
                    <div class="icon-box mx-auto mb-2" style="background:@item.Color;width:55px;height:55px;">
                        <i class="bi @item.Icon" style="color:@item.IColor;font-size:1.3rem;"></i>
                    </div>
                    <h6 class="fw-bold mt-2">@item.Title</h6>
                    <p class="small text-muted mb-0">@item.Desc</p>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function claimRewards() {
            alert('₦@cashback.ToString("N2") has been added to your wallet!');
        }
    </script>
}

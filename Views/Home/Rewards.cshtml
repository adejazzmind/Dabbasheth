@{
    ViewData["Title"] = "Rewards Hub";
    decimal cashback = ViewBag.Cashback ?? 0.00m;
}

<div class="container mt-5" style="padding-bottom: 120px;">
    <div class="text-center mb-5">
        <div class="bg-soft-warning d-inline-block p-4 rounded-circle mb-3">
            <i class="bi bi-gift-fill text-warning display-4"></i>
        </div>
        <h2 class="fw-bold">Rewards Hub</h2>
        <p class="text-muted">You earn as you save and spend with Dabbasheth.</p>
    </div>

    @* Cashback Card *@
    <div class="card card-dab border-0 shadow-lg p-4 mb-4 text-center">
        <small class="text-uppercase fw-bold text-muted" style="letter-spacing: 2px;">Total Cashback Earned</small>
        <h1 class="display-4 fw-bold text-success my-3">₦@cashback.ToString("N2")</h1>
        <button class="btn btn-primary btn-lg rounded-pill px-5 fw-bold" onclick="claimRewards()">
            Claim to Wallet
        </button>
    </div>

    @* How to Earn *@
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card card-dab border-0 p-4 h-100 shadow-sm text-center">
                <i class="bi bi-piggy-bank h1 text-primary"></i>
                <h5 class="fw-bold mt-3">Save Daily</h5>
                <p class="small text-muted">Earn 1% cashback on every successful daily thrift contribution.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-dab border-0 p-4 h-100 shadow-sm text-center">
                <i class="bi bi-phone-vibrate h1 text-info"></i>
                <h5 class="fw-bold mt-3">Pay Bills</h5>
                <p class="small text-muted">Get ₦50 instant reward when you buy airtime or data.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-dab border-0 p-4 h-100 shadow-sm text-center">
                <i class="bi bi-people h1 text-success"></i>
                <h5 class="fw-bold mt-3">Refer & Earn</h5>
                <p class="small text-muted">Earn ₦500 for every friend who joins and saves.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function claimRewards() {
            Swal.fire({
                title: 'Move to Wallet?',
                text: "Your cashback will be added to your main balance instantly.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#00D09C',
                cancelButtonColor: '#A3AED0',
                confirmButtonText: 'Yes, Claim it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire('Claimed!', '₦@cashback has been added to your wallet.', 'success');
                }
            })
        }
    </script>
}
@model List<Dabbasheth.Models.TransactionRecord>
@{
    ViewData["Title"] = "Dabbasheth Dashboard";
    string boldName = TempData.Peek("UserName") as string ?? "Valued Member";
    var hour = DateTime.Now.Hour;
    string timeGreeting = hour < 12 ? "Good morning" : hour < 17 ? "Good afternoon" : "Good evening";
}

@* --- 1. ASSETS --- *@
<audio id="successSound" src="https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3" preload="auto"></audio>

@* --- 2. MODALS --- *@
<div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 card-dab shadow-lg">
            <div class="modal-body p-5 text-center">
                <lottie-player src="https://assets10.lottiefiles.com/packages/lf20_afwjh8re.json" background="transparent" speed="1" style="width: 180px; height: 180px; margin: 0 auto;" autoplay></lottie-player>
                <h3 class="fw-bold mt-4 text-success">Request Received!</h3>
                <p class="text-muted small">Your transaction is logged and awaiting verification.</p>
                <button type="button" class="btn btn-primary btn-lg w-100 mt-4 rounded-pill shadow-sm" data-bs-dismiss="modal">Continue</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="receiptModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 card-dab shadow-lg">
            <div id="receiptContent" class="modal-body p-5 text-center">
                <div class="mb-4">
                    <div class="bg-soft-primary d-inline-block p-3 rounded-circle mb-3">
                        <i class="bi bi-receipt text-success display-4"></i>
                    </div>
                    <h4 class="fw-bold">Transaction Receipt</h4>
                </div>
                <div class="text-start bg-light p-4 rounded-4 my-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Status</span>
                        <span id="modalStatus" class="badge-dab"></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Amount</span>
                        <h5 id="modalAmount" class="fw-bold text-success mb-0"></h5>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small">Reference</span>
                        <span id="modalRef" class="fw-bold text-dark small"></span>
                    </div>
                </div>
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-primary btn-lg rounded-pill py-3">Download Receipt</button>
                    <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Close</button>
                </div>
                <div class="receipt-footer mt-4 pt-3 border-top border-dashed">
                    <small class="text-muted">© 2026 - Dabbasheth Secure Wallet</small>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- 3. UI LAYOUT --- *@
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            
            @* Greeting *@
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="text-muted mb-0">@timeGreeting,</h4>
                    <h1 class="fw-bold text-dark" style="letter-spacing: -1.5px; font-size: 2.8rem;">@boldName</h1>
                </div>
                <div class="bg-soft-secondary rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 55px; height: 55px;">
                    <i class="bi bi-person-check-fill text-primary h3 mb-0"></i>
                </div>
            </div>

            @* Wallet Card *@
            <div class="card balance-card text-white mb-5 border-0 p-2 shadow-lg">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="text-uppercase mb-0 opacity-75" style="letter-spacing: 1.5px;">Wallet Balance</h6>
                        <button class="btn text-white p-0 shadow-none" onclick="toggleBalance()">
                            <i class="bi bi-eye-fill" id="eyeIcon" style="font-size: 1.6rem;"></i>
                        </button>
                    </div>
                    <div class="my-3">
                        <h1 class="display-3 fw-bold mb-0" id="balanceText">₦@ViewBag.Balance.ToString("N2")</h1>
                        <h1 class="display-3 fw-bold mb-0 d-none" id="hiddenStars">₦ **** ****</h1>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <p class="mb-0 small opacity-75"><i class="bi bi-shield-lock-fill me-1"></i> Secured Account</p>
                        <i class="bi bi-wifi h4 mb-0 opacity-25"></i>
                    </div>
                </div>
            </div>

            @* Quick Actions Grid *@
            <div class="row text-center mb-5 g-2">
                <div class="col-3">
                    <form id="addMoneyForm" asp-controller="Payment" asp-action="InitializePayment" method="post">
                        <input type="hidden" name="email" value="@ViewBag.UserEmail" />
                        <button type="button" class="p-0 border-0 bg-transparent w-100 shadow-none" onclick="handleTransaction('addMoneyForm')">
                            <div class="rounded-circle bg-soft-primary mx-auto mb-2 d-flex align-items-center justify-content-center shadow-sm action-icon" style="width: 65px; height: 65px;">
                                <i class="bi bi-plus-circle-fill text-success h2 mb-0"></i>
                            </div>
                            <small class="fw-bold text-dark">Add Money</small>
                        </button>
                    </form>
                </div>
                <div class="col-3">
                    <a href="@Url.Action("Withdraw", "Home")" class="text-decoration-none">
                        <div class="rounded-circle bg-soft-danger mx-auto mb-2 d-flex align-items-center justify-content-center shadow-sm action-icon" style="width: 65px; height: 65px;">
                            <i class="bi bi-bank2 text-danger h2 mb-0"></i>
                        </div>
                        <small class="fw-bold text-dark">Withdraw</small>
                    </a>
                </div>
                <div class="col-3">
                    <a href="@Url.Action("PayBills", "Home")" class="text-decoration-none">
                        <div class="rounded-circle bg-soft-secondary mx-auto mb-2 d-flex align-items-center justify-content-center shadow-sm action-icon" style="width: 65px; height: 65px;">
                            <i class="bi bi-lightbulb-fill text-warning h2 mb-0"></i>
                        </div>
                        <small class="fw-bold text-dark">Pay Bills</small>
                    </a>
                </div>
                <div class="col-3">
                    <a href="@Url.Action("Loan", "Home")" class="text-decoration-none">
                        <div class="rounded-circle bg-soft-info mx-auto mb-2 d-flex align-items-center justify-content-center shadow-sm action-icon" style="width: 65px; height: 65px;">
                            <i class="bi bi-lightning-charge-fill text-info h2 mb-0"></i>
                        </div>
                        <small class="fw-bold text-dark">Loan Hub</small>
                    </a>
                </div>
            </div>

            @* FIX: Wealth Goals & Rewards Cards *@
            <div class="row mb-5 g-3">
                <div class="col-6">
                    <a href="@Url.Action("Thrift", "Home")" class="text-decoration-none">
                        <div class="card h-100 card-dab shadow-sm border-start border-success border-5">
                            <div class="card-body p-3">
                                <h6 class="fw-bold mb-0 text-success">Daily & Weekly Savings</h6>
                                <small class="text-muted">Create Wealth Goals</small>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-6">
                    <a href="@Url.Action("Rewards", "Home")" class="text-decoration-none">
                        <div class="card h-100 card-dab shadow-sm border-start border-warning border-5">
                            <div class="card-body p-3">
                                <h6 class="fw-bold mb-0 text-warning">Rewards Hub</h6>
                                <small class="text-muted">Claim your cashbacks</small>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            @* TRANSACTION LEDGER *@
            <div class="card card-dab shadow-sm mb-5 border-0">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Transaction Ledger</h4>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="text-muted small text-uppercase">
                                <tr>
                                    <th class="ps-3 border-0">Date</th>
                                    <th class="border-0">Amount</th>
                                    <th class="border-0 text-end pe-3">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var txn in Model)
                                    {
                                        var isNegative = txn.Amount < 0;
                                        <tr class="transaction-row pointer" onclick="showReceipt('@txn.Reference', '@txn.Amount.ToString("N2")', '@txn.Date.ToString("MMM dd, HH:mm")', '@txn.Status')">
                                            <td class="ps-3 border-0">
                                                <div class="fw-bold text-dark">@txn.Date.ToString("MMM dd")</div>
                                                <div class="small text-muted">@txn.Date.ToString("t")</div>
                                            </td>
                                            <td class="fw-bold border-0 @(isNegative ? "text-danger" : "text-success")">
                                                @(isNegative ? "" : "+")₦@Math.Abs(txn.Amount).ToString("N2")
                                            </td>
                                            <td class="text-end pe-3 border-0">
                                                <span class="badge-dab @(txn.Status.Contains("Approved") ? "bg-soft-primary" : "bg-soft-secondary")">@txn.Status</span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var msg = '@TempData["Message"]';
            if (msg) {
                document.getElementById("successSound").play();
                new bootstrap.Modal(document.getElementById('successModal')).show();
            }
        });

        function toggleBalance() {
            $('#balanceText').toggleClass('d-none');
            $('#hiddenStars').toggleClass('d-none');
            $('#eyeIcon').toggleClass('bi-eye-fill bi-eye-slash-fill');
        }

        function showReceipt(ref, amount, date, status) {
            $('#modalRef').text(ref);
            $('#modalAmount').text('₦' + amount);
            const badge = $('#modalStatus');
            badge.text(status).attr('class', 'badge-dab ' + (status.includes('Approved') ? 'bg-soft-primary' : 'bg-soft-secondary'));
            new bootstrap.Modal(document.getElementById('receiptModal')).show();
        }
    </script>
}
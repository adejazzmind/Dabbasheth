@model Dabbasheth.Models.UserDashboardViewModel
@{ Layout = "_Layout"; ViewData["Title"] = "Dashboard"; var unread = ViewBag.UnreadMessages as int? ?? 0; }
<style>
.dash-wrap{padding:0 0 90px}
.hero-card{background:linear-gradient(135deg,#0A0F1E 0%,#1A2744 40%,#0E3A8C 100%);color:#fff;padding:28px 24px 24px;position:relative;overflow:hidden}
.hero-card::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(14,165,233,.4) 0%,transparent 70%)}
.hero-card::after{content:'';position:absolute;bottom:-30px;left:20%;width:120px;height:120px;border-radius:50%;background:radial-gradient(circle,rgba(26,115,232,.25) 0%,transparent 70%)}
.balance-lbl{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;opacity:.6;margin-bottom:6px}
.balance-num{font-size:2.4rem;font-weight:900;letter-spacing:-1.5px;position:relative;z-index:1}
.hero-btns{display:flex;gap:10px;margin-top:22px;position:relative;z-index:1}
.h-btn{flex:1;border-radius:14px;padding:13px;font-size:.85rem;font-weight:700;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;text-decoration:none;transition:.2s;font-family:'Inter',sans-serif}
.h-btn:hover{transform:translateY(-2px)}
.h-btn-primary{background:#F59E0B;color:#0A0F1E}
.h-btn-secondary{background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.2)}
.section{padding:0 16px;margin-top:20px}
.section-title{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#94A3B8;margin-bottom:12px}
.quick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.q-item{background:#fff;border-radius:18px;padding:16px 8px;text-align:center;text-decoration:none;border:1px solid #F1F5F9;transition:.2s}
.q-item:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.08);border-color:#BFDBFE}
.q-icon{width:44px;height:44px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;margin:0 auto 8px}
.q-label{font-size:.7rem;font-weight:600;color:#374151}
.stats-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:20px}
.stat-box{background:#fff;border-radius:18px;padding:18px;border:1px solid #F1F5F9}
.stat-box .num{font-size:1.5rem;font-weight:800;color:#0F172A}
.stat-box .lbl{font-size:.72rem;font-weight:600;color:#94A3B8;margin-top:2px}
.stat-box .sub{font-size:.72rem;font-weight:600;color:#1A73E8;margin-top:6px}
.tx-card{background:#fff;border-radius:18px;border:1px solid #F1F5F9;overflow:hidden;margin-top:20px}
.tx-item{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid #F8FAFC;transition:.15s}
.tx-item:last-child{border-bottom:none}
.tx-item:hover{background:#F8FAFC}
.tx-icon{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.tx-desc{font-weight:600;font-size:.83rem;color:#0F172A}
.tx-date{font-size:.7rem;color:#94A3B8;margin-top:2px}
.tx-amt{font-weight:700;font-size:.88rem}
.chat-fab{position:fixed;bottom:90px;right:18px;width:52px;height:52px;background:linear-gradient(135deg,#1A73E8,#0EA5E9);border-radius:16px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.3rem;text-decoration:none;box-shadow:0 8px 24px rgba(26,115,232,.4);z-index:150;transition:.3s}
.chat-fab:hover{transform:scale(1.1);color:#fff}
.chat-fab .notif{position:absolute;top:-6px;right:-6px;background:#EF4444;color:#fff;border-radius:99px;font-size:.6rem;font-weight:700;min-width:18px;height:18px;display:flex;align-items:center;justify-content:center;border:2px solid #fff}
@@media(min-width:992px){.dash-wrap{padding:24px 0 24px}.hero-card{border-radius:24px;margin:0 0 0}.section{padding:0 24px}.quick-grid{grid-template-columns:repeat(4,1fr)}}
</style>

<div class="dash-wrap">
    @* ── HERO WALLET CARD ── *@
    <div class="hero-card">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px">
            <div>
                <div style="font-size:.8rem;opacity:.6;margin-bottom:2px">Welcome back,</div>
                <div style="font-weight:700;font-size:1.1rem">@TempData.Peek("UserName")</div>
            </div>
            <a href="/Account/Profile" style="width:40px;height:40px;background:rgba(255,255,255,.12);border-radius:12px;display:flex;align-items:center;justify-content:center;text-decoration:none;">
                <i class="bi bi-person-fill" style="color:#fff;font-size:1.1rem"></i>
            </a>
        </div>

        <div class="balance-lbl">Wallet Balance</div>
        @if(Model.Wallet != null){
            <div class="balance-num">₦@Model.Wallet.Balance.ToString("N2")</div>
            <div style="font-size:.75rem;opacity:.5;margin-top:4px;position:relative;z-index:1">@Model.Wallet.WalletNumber</div>
        } else {
            <div class="balance-num">₦0.00</div>
        }

        <div class="hero-btns">
            <a href="/Home/Withdraw" class="h-btn h-btn-secondary"><i class="bi bi-arrow-up-right"></i>Withdraw</a>
            <a href="/Wallet/FundWallet" class="h-btn h-btn-primary"><i class="bi bi-plus-lg"></i>Fund Wallet</a>
        </div>
    </div>

    @* ── QUICK ACTIONS ── *@
    <div class="section">
        <p class="section-title">Quick Actions</p>
        <div class="quick-grid">
            <a href="/Home/Airtime" class="q-item">
                <div class="q-icon" style="background:#EFF6FF"><i class="bi bi-phone-fill" style="color:#1A73E8"></i></div>
                <div class="q-label">Airtime</div>
            </a>
            <a href="/Home/Data" class="q-item">
                <div class="q-icon" style="background:#ECFDF5"><i class="bi bi-wifi" style="color:#10B981"></i></div>
                <div class="q-label">Data</div>
            </a>
            <a href="/Home/Thrift" class="q-item">
                <div class="q-icon" style="background:#FFF7ED"><i class="bi bi-piggy-bank-fill" style="color:#F59E0B"></i></div>
                <div class="q-label">Savings</div>
            </a>
            <a href="/Home/PayBills" class="q-item">
                <div class="q-icon" style="background:#F5F3FF"><i class="bi bi-lightning-fill" style="color:#8B5CF6"></i></div>
                <div class="q-label">Bills</div>
            </a>
        </div>
    </div>

    @* ── STATS ── *@
    <div class="section">
        <div class="stats-row">
            <div class="stat-box">
                <div class="lbl">Total Savings</div>
                <div class="num">₦@Model.ThriftPlans.Sum(p=>p.CurrentSavings).ToString("N0")</div>
                <div class="sub">@Model.ThriftPlans.Count Active Goals</div>
            </div>
            <div class="stat-box">
                <div class="lbl">Ajo Groups</div>
                <div class="num">@Model.ThriftGroups.Count</div>
                <div class="sub">In Rotation</div>
            </div>
        </div>
    </div>

    @* ── TRANSACTIONS ── *@
    <div class="section">
        <p class="section-title" style="margin-top:20px">Recent Activity</p>
        <div class="tx-card">
            @if(Model.RecentTransactions.Any()){
                @foreach(var tx in Model.RecentTransactions){
                    var isCredit = tx.Type=="Credit";
                    <div class="tx-item">
                        <div style="display:flex;align-items:center;gap:12px">
                            <div class="tx-icon" style="background:@(isCredit?"#ECFDF5":"#FEF2F2")">
                                <i class="bi @(isCredit?"bi-arrow-down-left":"bi-arrow-up-right")" style="color:@(isCredit?"#10B981":"#EF4444")"></i>
                            </div>
                            <div>
                                <div class="tx-desc">@(tx.Description.Length>32?tx.Description[..32]+"…":tx.Description)</div>
                                <div class="tx-date">@tx.Date.ToLocalTime().ToString("dd MMM, HH:mm")</div>
                            </div>
                        </div>
                        <div style="text-align:right">
                            <div class="tx-amt" style="color:@(isCredit?"#10B981":"#EF4444")">
                                @(isCredit?"+":"-")₦@tx.Amount.ToString("N0")
                            </div>
                            <div style="font-size:.65rem;color:#94A3B8">@tx.Status</div>
                        </div>
                    </div>
                }
            } else {
                <div style="padding:50px;text-align:center;color:#CBD5E1">
                    <i class="bi bi-receipt-cutoff" style="font-size:2.5rem;display:block;margin-bottom:10px"></i>
                    <span style="font-size:.85rem">No transactions yet</span>
                </div>
            }
        </div>
    </div>
</div>

@* ── FLOATING CHAT BUTTON ── *@
<a href="/Home/Chat" class="chat-fab d-lg-none">
    <i class="bi bi-headset"></i>
    @if(unread>0){ <span class="notif">@unread</span> }
</a>



@model List<Dabbasheth.Models.TransactionRecord>
@{
    Layout = "_Layout";
    var userName = TempData.Peek("UserName")?.ToString() ?? "User";
}

@* --- 📱 MOBILE-FIRST CSS --- *@
<style>
    html, body {
        overflow-x: hidden;
        overscroll-behavior-y: contain;
        background-color: #fbfbfb;
    }

    /* Fixed Glass Header */
    .app-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(15px);
        z-index: 2000;
        display: flex;
        align-items: center;
        padding: 0 20px;
        border-bottom: 1px solid rgba(212, 175, 55, 0.1);
    }

    /* Safe Content Area */
    .app-content {
        padding-top: 85px;
        padding-bottom: 100px;
    }

    /* High-End Card Styling */
    .premium-card {
        border: none;
        background: linear-gradient(135deg, #014134 0%, #001f1a 100%);
        border-radius: 28px;
        padding: 24px;
        position: relative;
        box-shadow: 0 20px 30px rgba(1, 65, 52, 0.2);
    }

    /* Floating Navigation (Apple/Fintech Style) */
    .mobile-nav {
        position: fixed;
        bottom: 20px;
        left: 20px;
        right: 20px;
        height: 65px;
        background: #FFFFFF;
        border-radius: 50px;
        display: flex;
        justify-content: space-around;
        align-items: center;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        z-index: 2000;
        border: 1px solid rgba(0,0,0,0.03);
    }

    .nav-item {
        text-decoration: none;
        color: #8E8E93;
        text-align: center;
        transition: all 0.3s ease;
    }

    .nav-item.active { color: #D4AF37; }

    .icon-box {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: #fff;
        box-shadow: 0 4px 10px rgba(0,0,0,0.04);
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .action-link { text-decoration: none; transition: transform 0.2s; }
    .action-link:active { transform: scale(0.9); }
</style>

@* --- 1. THE APP HEADER --- *@
<div class="app-header justify-content-between">
    <div class="d-flex align-items-center">
        <div class="position-relative">
            <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(userName)&background=014134&color=D4AF37&bold=true"
                 class="rounded-circle shadow-sm" width="40" alt="Avatar">
            <div class="position-absolute border border-white rounded-circle bg-success" style="width:10px; height:10px; bottom:2px; right:2px;"></div>
        </div>
        <div class="ms-3">
            <h6 class="mb-0 fw-bold text-dark" style="font-size: 0.95rem;">@userName</h6>
            <small class="text-gold fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">URBAN PREMIER</small>
        </div>
    </div>
    <div class="d-flex gap-3">
        <div class="bg-light rounded-circle p-2"><i class="bi bi-qr-code-scan text-dark"></i></div>
        <div class="bg-light rounded-circle p-2 position-relative">
            <i class="bi bi-bell text-dark"></i>
            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
        </div>
    </div>
</div>

@* --- 2. MAIN APP CONTENT --- *@
<div class="app-content container">

    @* Balance Card *@
    <div class="premium-card mb-4">
        <div class="d-flex justify-content-between align-items-start text-white">
            <div>
                <p class="mb-0 opacity-75 small text-uppercase">Wallet Balance</p>
                <h2 class="fw-bold mb-0">₦@ViewBag.Balance.ToString("N2")</h2>
            </div>
            <i class="bi bi-eye-fill opacity-50 h4"></i>
        </div>

        @* Integrated Money Operations *@
        <div class="mt-4 d-flex gap-2">
            <form asp-controller="Payment" asp-action="InitializePayment" method="post" class="flex-grow-1">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@ViewBag.UserEmail" />
                <input type="hidden" name="amount" value="5000" />
                <button type="submit" class="btn btn-light w-100 rounded-pill fw-bold py-2 shadow-sm" style="color: #014134;">
                    <i class="bi bi-plus-circle me-1"></i> Add Money
                </button>
            </form>
            <a href="@Url.Action("Withdraw", "Home")" class="btn btn-outline-light rounded-pill px-4 fw-bold py-2 border-0 d-flex align-items-center" style="background: rgba(255,255,255,0.1);">
                Withdraw
            </a>
        </div>
        
        @* Gold Accent Detail *@
        <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 4px; background: #D4AF37; border-radius: 0 0 28px 28px;"></div>
    </div>

    @* Features Grid - Fixed Redirect Logic *@
    <div class="row mt-4 g-3 text-center px-1">
        @{
            var services = new[] {
                new { Name = "Transfer", Icon = "bi-bank", Color = "text-success", Action = "Withdraw" },
                new { Name = "Airtime", Icon = "bi-phone", Color = "text-info", Action = "PayBills" },
                new { Name = "Data", Icon = "bi-wifi", Color = "text-primary", Action = "PayBills" },
                new { Name = "Betting", Icon = "bi-controller", Color = "text-danger", Action = "PayBills" },
                new { Name = "Savings", Icon = "bi-piggy-bank", Color = "text-gold", Action = "Thrift" },
                new { Name = "TV", Icon = "bi-display", Color = "text-warning", Action = "PayBills" },
                new { Name = "Electric", Icon = "bi-lightning-charge", Color = "text-warning", Action = "PayBills" },
                new { Name = "Withdraw", Icon = "bi-wallet2", Color = "text-secondary", Action = "Withdraw" }
            };
        }

        @foreach (var s in services)
        {
            <div class="col-3">
                <a href="@Url.Action(s.Action, "Home")" class="action-link">
                    <div class="icon-box mx-auto">
                        <i class="bi @s.Icon @s.Color h4 mb-0"></i>
                    </div>
                    <p class="small fw-bold text-dark mt-1 mb-0" style="font-size: 0.65rem;">@s.Name</p>
                </a>
            </div>
        }
    </div>

    @* Recent Activity *@
    <div class="mt-5 mb-3 d-flex justify-content-between align-items-center px-1">
        <h6 class="fw-bold mb-0">Urban Activity</h6>
        <small class="text-gold fw-bold">See All</small>
    </div>

    <div class="bg-white rounded-4 shadow-sm p-1 mb-5">
        @if (Model != null && Model.Any())
        {
            @foreach (var tx in Model.Take(4))
            {
                <div class="p-3 d-flex justify-content-between align-items-center border-bottom border-light">
                    <div class="d-flex align-items-center">
                        <div class="bg-soft-gold p-2 rounded-3 me-3" style="background: #fff9e6;">
                            <i class="bi bi-arrow-left-right text-gold"></i>
                        </div>
                        <div>
                            <p class="mb-0 fw-bold small text-dark">@tx.Description</p>
                            <small class="text-muted" style="font-size: 0.6rem;">@tx.Date.ToString("dd MMM") • <span class="text-uppercase fw-bold text-gold" style="font-size: 0.55rem;">@tx.Status</span></small>
                        </div>
                    </div>
                    <p class="mb-0 fw-bold small text-dark">₦@tx.Amount.ToString("N0")</p>
                </div>
            }
        }
        else
        {
            <div class="p-4 text-center opacity-50">
                <i class="bi bi-clock-history h2"></i>
                <p class="small mt-2">No urban activity yet</p>
            </div>
        }
    </div>
</div>

@* --- 3. FLOATING NAV --- *@
<div class="mobile-nav">
    <a href="@Url.Action("Index", "Home")" class="nav-item active">
        <i class="bi bi-house-door-fill h4 mb-0"></i>
        <p class="small mb-0 fw-bold" style="font-size: 0.6rem;">Hub</p>
    </a>
    <a href="#" class="nav-item">
        <i class="bi bi-gift h4 mb-0"></i>
        <p class="small mb-0 fw-bold" style="font-size: 0.6rem;">Gift</p>
    </a>
    <a href="@Url.Action("Thrift", "Home")" class="nav-item">
        <i class="bi bi-compass h4 mb-0"></i>
        <p class="small mb-0 fw-bold" style="font-size: 0.6rem;">Finance</p>
    </a>
    <a href="@Url.Action("Profile", "Home")" class="nav-item">
        <i class="bi bi-person h4 mb-0"></i>
        <p class="small mb-0 fw-bold" style="font-size: 0.6rem;">Profile</p>
    </a>
</div>
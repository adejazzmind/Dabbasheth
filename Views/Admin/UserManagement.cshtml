@model IEnumerable<Dabbasheth.Models.User>
@{
    Layout = "_Layout";
}

<div class="p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Customer Ledger</h4>
        <button class="btn btn-dark rounded-pill px-4">+ Add User</button>
    </div>

    <div class="card border-0 shadow-sm rounded-5 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Full Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@user.FullName</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge @(user.IsVerified ? "bg-success" : "bg-warning") rounded-pill">
                                    @(user.IsVerified ? "Verified" : "Pending")
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-outline-primary btn-sm rounded-pill px-3">View Profile</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
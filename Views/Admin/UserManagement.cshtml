@model IEnumerable<Dabbasheth.Models.User>
@{
    Layout = "_Layout";
}

<div class="p-4">
    @* --- Header Section --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Customer Ledger</h4>
            <p class="text-muted small mb-0">Manage hub members, verification status, and account security.</p>
        </div>
        <button class="btn btn-dark rounded-pill px-4 shadow-sm">+ Add User</button>
    </div>

    @* --- Stats Bar (Optional but World-Class) --- *@
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card card-dab p-3 border-0 shadow-sm rounded-4">
                <small class="text-muted d-block">Total Members</small>
                <h4 class="fw-bold mb-0">@Model.Count()</h4>
            </div>
        </div>
    </div>

    @* --- Main Ledger Table --- *@
    <div class="card border-0 shadow-sm rounded-5 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">Full Name</th>
                        <th>Email</th>
                        <th>Identity</th>
                        <th>Account Status</th>
                        <th class="text-end pe-4">Executive Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm me-3 fw-bold text-white" style="background: var(--brand-blue); border-radius: 10px; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;">
                                        @user.FullName.Substring(0, 1)
                                    </div>
                                    <span class="fw-bold">@user.FullName</span>
                                </div>
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                @* Verification Status Check *@
                                <span class="badge @(user.IsVerified ? "bg-soft-success text-success" : "bg-soft-warning text-warning") rounded-pill px-3">
                                    <i class="bi @(user.IsVerified ? "bi-patch-check-fill" : "bi-hourglass-split") me-1"></i>
                                    @(user.IsVerified ? "Verified" : "Pending")
                                </span>
                            </td>
                            <td>
                                @* ❄️ Freeze/Unfreeze Status Display *@
                                <span class="badge @(user.Status == "Active" ? "bg-success" : "bg-danger") px-3">
                                    @user.Status
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    @* ✅ View Profile Button *@
                                    <button class="btn btn-light btn-sm rounded-pill px-3 fw-bold">View</button>

                                    @* ❄️ Toggle Status Form *@
                                    <form asp-action="ToggleUserStatus" asp-route-id="@user.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-sm rounded-pill px-3 @(user.Status == "Active" ? "btn-outline-danger" : "btn-success")">
                                            <i class="bi @(user.Status == "Active" ? "bi-snow" : "bi-play-fill") me-1"></i>
                                            @(user.Status == "Active" ? "Freeze" : "Unfreeze")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@model Dabbasheth.Models.AdminDashboardViewModel
@{ Layout = "_Layout"; }

<div class="container-fluid py-4 bg-light min-vh-100 px-lg-4">
    <div class="mb-4 px-2">
        <h4 class="fw-bold mb-0 text-danger"><i class="bi bi-shield-exclamation me-2"></i>Risk Control Center</h4>
        <p class="text-muted small">Monitor suspicious activity and protect system liquidity</p>
    </div>

    @* 🚩 HIGH-VALUE TRANSACTION MONITOR *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 bg-white">
        <div class="card-header bg-white py-3 border-0">
            <h6 class="fw-bold mb-0"><i class="bi bi-eye-fill me-2 text-warning"></i>High-Value Alerts (>₦500k)</h6>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-light small text-muted">
                    <tr>
                        <th class="ps-4">Reference</th>
                        <th>User</th>
                        <th>Amount</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.PendingTransactions != null && Model.PendingTransactions.Any(t => t.Amount >= 500000))
                    {
                        @foreach (var tx in Model.PendingTransactions.Where(t => t.Amount >= 500000))
                        {
                            <tr>
                                <td class="ps-4"><code class="small">@tx.Reference</code></td>
                                <td class="small">@tx.UserEmail</td>
                                <td class="fw-bold text-danger">₦@tx.Amount.ToString("N2")</td>
                                <td class="text-end pe-4">
                                    <form asp-action="FlagTransaction" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="reference" value="@tx.Reference" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Flag</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center py-5 text-muted small">No high-value risks detected.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ❄️ ACCOUNT FREEZE/THAW PANEL *@
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <h6 class="fw-bold mb-3"><i class="bi bi-snow2 me-2 text-info"></i>Account Lockdown Logic</h6>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light small text-muted">
                    <tr>
                        <th class="ps-4">Member Name</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Control</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.AllUsers.Where(u => u.Role == "Customer"))
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@user.FullName</div>
                                <small class="text-muted">@user.Email</small>
                            </td>
                            <td>
                                <span class="badge @(user.Status == "Active" ? "bg-soft-success text-success" : "bg-soft-danger text-danger") rounded-pill">
                                    @user.Status
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <form asp-action="ToggleUserStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="email" value="@user.Email" />
                                    <button type="submit" class="btn @(user.Status == "Active" ? "btn-danger" : "btn-success") btn-sm rounded-pill px-3 fw-bold">
                                        @(user.Status == "Active" ? "Freeze" : "Restore")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-soft-success { background: rgba(25, 135, 84, 0.1); }
    .bg-soft-danger { background: rgba(220, 53, 69, 0.1); }
</style>
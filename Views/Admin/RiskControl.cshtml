@model Dabbasheth.Models.AdminDashboardViewModel
@{
    Layout = "_Layout"; ViewData["Title"] = "Risk Control";
}

<div class="container-fluid p-4">
    <div class="mb-4">
        <h4 class="fw-bold mb-1 text-danger"><i class="bi bi-shield-exclamation me-2"></i>Risk Control Center</h4>
        <p class="text-muted small">Monitor suspicious activity and protect system liquidity.</p>
    </div>

    @* ── HIGH VALUE ALERTS ── *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 bg-white">
        <div class="card-header bg-white py-3 border-0">
            <h6 class="fw-bold mb-0"><i class="bi bi-eye-fill me-2 text-warning"></i>High-Value Alerts (&gt;₦500k)</h6>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-light small text-muted text-uppercase">
                    <tr>
                        <th class="ps-4">TX ID</th>
                        <th>User</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var highValue = Model.PendingTransactions?.Where(t => t.Amount >= 500000).ToList();
                    }
                    @if (highValue != null && highValue.Any())
                    {
                        @foreach (var tx in highValue)
                        {
                            <tr>
                                <td class="ps-4"><code class="small">TX-@tx.Id</code></td>
                                <td class="small">@tx.UserEmail</td>
                                <td class="fw-bold text-danger">₦@tx.Amount.ToString("N2")</td>
                                <td><span class="badge bg-warning text-dark rounded-pill">@tx.Status</span></td>
                                <td class="text-end pe-4">
                                    <form asp-action="FlagTransaction" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="transactionId" value="@tx.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold">Flag</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted small">No high-value risks detected.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ── ACCOUNT FREEZE PANEL ── *@
    <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
        <h6 class="fw-bold mb-3"><i class="bi bi-snow2 me-2 text-info"></i>Account Lockdown Control</h6>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light small text-muted text-uppercase">
                    <tr>
                        <th class="ps-4">Member</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Control</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AllUsers != null)
                    {
                        @foreach (var user in Model.AllUsers.Where(u => u.Role == "Customer"))
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@user.FullName</div>
                                    <small class="text-muted">@user.Email</small>
                                </td>
                                <td>
                                    <span class="badge rounded-pill px-2 @(user.Status == "Active" ? "bg-success" : "bg-danger")">
                                        @user.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <form asp-action="ToggleUserStatus" asp-route-id="@user.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm rounded-pill px-3 fw-bold @(user.Status == "Active" ? "btn-danger" : "btn-success")">
                                            @(user.Status == "Active" ? "Freeze" : "Restore")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

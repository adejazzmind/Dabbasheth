@model Dabbasheth.Models.AdminDashboardViewModel
@{
    Layout = "_Layout"; ViewData["Title"] = "Ajo Engine";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Ajo Group Engine</h4>
            <p class="text-muted small mb-0">Manage rotational savings cycles and member slots.</p>
        </div>
        <button class="btn rounded-pill px-4 fw-bold text-white shadow-sm"
                style="background:linear-gradient(135deg,#1A73E8,#00B4DB);"
                data-bs-toggle="modal" data-bs-target="#newGroupModal">
            <i class="bi bi-plus-lg me-1"></i> New Cycle
        </button>
    </div>

    @* ── STATS ── *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white text-center">
                <small class="text-muted d-block fw-bold text-uppercase mb-1" style="font-size:0.62rem;">Active Cycles</small>
                <h4 class="fw-bold mb-0">@(Model.AllThriftGroups?.Count ?? 0)</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white text-center">
                <small class="text-muted d-block fw-bold text-uppercase mb-1" style="font-size:0.62rem;">Total Pool</small>
                <h4 class="fw-bold mb-0 text-primary">
                    ₦@((Model.AllThriftGroups?.Sum(g => g.CategoryAmount * (g.MemberPlans?.Count ?? 0)) ?? 0).ToString("N0"))
                </h4>
            </div>
        </div>
    </div>

    @* ── GROUP CARDS ── *@
    <div class="row g-4">
        @if (Model.AllThriftGroups != null && Model.AllThriftGroups.Any())
        {
            @foreach (var group in Model.AllThriftGroups)
            {
                <div class="col-12 col-xl-6">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white h-100">
                        <div class="p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold mb-1">@group.GroupName</h5>
                                    <span class="badge rounded-pill px-3"
                                          style="background:rgba(26,115,232,0.1);color:#1A73E8;">@group.Status</span>
                                </div>
                                <div class="text-end">
                                    <h4 class="fw-bold mb-0 text-primary">₦@((group.CategoryAmount * (group.MemberPlans?.Count ?? 0)).ToString("N0"))</h4>
                                    <small class="text-muted">Total Pool</small>
                                </div>
                            </div>

                            <div class="row g-2 mb-3">
                                <div class="col-4 text-center p-2 rounded-3 bg-light">
                                    <small class="text-muted d-block" style="font-size:0.65rem;">Monthly</small>
                                    <span class="fw-bold small">₦@group.MonthlyContribution.ToString("N0")</span>
                                </div>
                                <div class="col-4 text-center p-2 rounded-3 bg-light">
                                    <small class="text-muted d-block" style="font-size:0.65rem;">Slots</small>
                                    <span class="fw-bold small">@(group.MemberPlans?.Count ?? 0)</span>
                                </div>
                                <div class="col-4 text-center p-2 rounded-3 bg-light">
                                    <small class="text-muted d-block" style="font-size:0.65rem;">Term</small>
                                    <span class="fw-bold small">@group.DurationMonths mo</span>
                                </div>
                            </div>

                            @* Member Slot List *@
                            <h6 class="fw-bold small text-muted text-uppercase mb-2" style="font-size:0.65rem;letter-spacing:1px;">Rotational Queue</h6>
                            <div class="list-group list-group-flush border rounded-3 overflow-hidden mb-3">
                                @if (group.MemberPlans != null && group.MemberPlans.Any())
                                {
                                    @foreach (var m in group.MemberPlans.OrderBy(x => x.PayoutOrder))
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-3 bg-transparent">
                                            <div class="small">
                                                <span class="fw-bold text-primary me-2">#@m.PayoutOrder</span>
                                                <span class="text-muted">@m.UserEmail</span>
                                            </div>
                                            @if (m.HasCollected)
                                            {
                                                <span class="badge bg-success rounded-pill px-2"><i class="bi bi-check-lg"></i> Paid</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-muted border rounded-pill px-2">Waiting</span>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="p-3 text-center text-muted small">No members yet.</div>
                                }
                            </div>

                            <div class="d-flex gap-2">
                                <form asp-action="CloseGroup" method="post" class="flex-grow-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="groupId" value="@group.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill fw-bold"
                                            onclick="return confirm('Terminate this cycle?')">
                                        Terminate
                                    </button>
                                </form>
                                <button class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm"
                                        data-bs-toggle="modal" data-bs-target="#addMemberModal"
                                        onclick="setGroupId(@group.Id)">
                                    <i class="bi bi-person-plus-fill"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 text-muted">
                <i class="bi bi-diagram-3 display-1 opacity-25 d-block mb-3"></i>
                No active cycles. Create one to begin.
            </div>
        }
    </div>
</div>

@* ── MODAL: New Group ── *@
<div class="modal fade" id="newGroupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-5 shadow-lg">
            <div class="modal-header border-0 p-4 pb-0">
                <h5 class="fw-bold mb-0">Initialize Ajo Cycle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="CreateThriftGroup" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="small fw-bold text-muted mb-1">Group Name</label>
                        <input type="text" name="GroupName" class="form-control bg-light border-0 py-3 rounded-4" placeholder="e.g. Ogba Market Hub" required />
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-muted mb-1">Category Amount</label>
                        <select name="CategoryAmount" class="form-select bg-light border-0 py-3 rounded-4">
                            <option value="100000">₦100,000</option>
                            <option value="500000">₦500,000</option>
                            <option value="1000000">₦1,000,000</option>
                        </select>
                    </div>
                    <div class="row g-2 mb-4">
                        <div class="col-6">
                            <label class="small fw-bold text-muted mb-1">Duration</label>
                            <select name="DurationMonths" class="form-select bg-light border-0 py-3 rounded-4">
                                <option value="10">10 Months</option>
                                <option value="12">12 Months</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="small fw-bold text-muted mb-1">Monthly Contribution</label>
                            <input type="number" name="MonthlyContribution" class="form-control bg-light border-0 py-3 rounded-4" placeholder="₦10,000" required />
                        </div>
                    </div>
                    <button type="submit" class="btn w-100 rounded-pill py-3 fw-bold text-white"
                            style="background:linear-gradient(135deg,#1A73E8,#00B4DB);">
                        Deploy Cycle
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@* ── MODAL: Add Member ── *@
<div class="modal fade" id="addMemberModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-5 shadow-lg">
            <div class="modal-header border-0 p-4 pb-0">
                <h5 class="fw-bold mb-0">Add Member to Cycle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="AddMemberToGroup" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ThriftGroupId" id="modalGroupId" />
                    <div class="mb-3">
                        <label class="small fw-bold text-muted mb-1">Member Email</label>
                        <input type="email" name="UserEmail" class="form-control bg-light border-0 py-3 rounded-4" placeholder="member@email.com" required />
                    </div>
                    <div class="mb-4">
                        <label class="small fw-bold text-muted mb-1">Payout Slot #</label>
                        <input type="number" name="PayoutOrder" class="form-control bg-light border-0 py-3 rounded-4" placeholder="e.g. 1" min="1" required />
                    </div>
                    <button type="submit" class="btn w-100 rounded-pill py-3 fw-bold text-white"
                            style="background:linear-gradient(135deg,#1A73E8,#00B4DB);">
                        Confirm Slot
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function setGroupId(id) { document.getElementById('modalGroupId').value = id; }
</script>

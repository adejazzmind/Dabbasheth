@model Dabbasheth.Models.AdminDashboardViewModel
@{
    Layout = "_Layout";
}

<div class="p-4 animate__animated animate__fadeIn">
    @* --- Executive Header --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1" style="color: var(--brand-navy);">Ajo Group Engine</h4>
            <p class="text-muted small">Monitor rotational cycles, member slots, and pool health.</p>
        </div>
        <button class="btn login-btn rounded-pill px-4 shadow-sm fw-bold"
                data-bs-toggle="modal"
                data-bs-target="#newGroupModal">
            <i class="bi bi-plus-lg me-2"></i>New Cycle
        </button>
    </div>

    @* --- Engine Overview Stats --- *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card card-dab border-0 shadow-sm rounded-4 p-3 bg-white">
                <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.65rem;">Active Cycles</small>
                <h4 class="fw-bold mb-0" style="color: var(--brand-navy);">
                    @(Model.AllThriftGroups?.Count ?? 0)
                </h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-dab border-0 shadow-sm rounded-4 p-3 bg-white">
                <small class="text-muted d-block fw-bold text-uppercase" style="font-size: 0.65rem;">Total Ajo Assets</small>
                <h4 class="fw-bold mb-0" style="color: var(--brand-blue);">
                    ₦@(Model.AllThriftGroups?.Sum(g => g.CategoryAmount * (g.MemberPlans?.Count ?? 0)).ToString("N0") ?? "0")
                </h4>
            </div>
        </div>
    </div>

    @* --- Group Grid --- *@
    <div class="row g-4">
        @if (Model.AllThriftGroups != null && Model.AllThriftGroups.Any())
        {
            @foreach (var group in Model.AllThriftGroups)
            {
                <div class="col-12 col-xl-6">
                    <div class="card card-dab border-0 shadow-sm rounded-5 overflow-hidden bg-white h-100">
                        <div class="p-4">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div>
                                    <h5 class="fw-bold mb-0" style="color: var(--brand-navy);">@group.GroupName</h5>
                                    <span class="badge rounded-pill px-3 mt-1" style="background: rgba(26, 115, 232, 0.1); color: var(--brand-blue);">
                                        <i class="bi bi-record-circle-fill me-1"></i> @(group.Status ?? "Active")
                                    </span>
                                </div>
                                <div class="text-end">
                                    <h4 class="fw-bold mb-0" style="color: var(--brand-sky);">₦@((group.CategoryAmount * (group.MemberPlans?.Count ?? 0)).ToString("N0"))</h4>
                                    <small class="text-muted fw-bold small text-uppercase">Total Pool</small>
                                </div>
                            </div>

                            <div class="row g-2 mb-4">
                                <div class="col-4 text-center p-2 rounded-4" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
                                    <small class="text-muted d-block small">Monthly</small>
                                    <span class="fw-bold" style="color: var(--brand-navy);">₦@group.MonthlyContribution.ToString("N0")</span>
                                </div>
                                <div class="col-4 text-center p-2 rounded-4" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
                                    <small class="text-muted d-block small">Slots</small>
                                    <span class="fw-bold" style="color: var(--brand-navy);">@(group.MemberPlans?.Count ?? 0)</span>
                                </div>
                                <div class="col-4 text-center p-2 rounded-4" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
                                    <small class="text-muted d-block small">Term</small>
                                    <span class="fw-bold" style="color: var(--brand-navy);">@group.DurationMonths Mo</span>
                                </div>
                            </div>

                            <h6 class="fw-bold small mb-3 text-uppercase opacity-50" style="letter-spacing: 1px;">Rotational Queue</h6>
                            <div class="list-group list-group-flush border rounded-4 overflow-hidden mb-4 shadow-sm">
                                @if (group.MemberPlans != null && group.MemberPlans.Any())
                                {
                                    @foreach (var member in group.MemberPlans.OrderBy(m => m.PayoutOrder))
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-3 bg-transparent">
                                            <div class="small">
                                                <span class="fw-bold me-2" style="color: var(--brand-blue);">#@member.PayoutOrder</span>
                                                <span class="text-muted">@member.UserEmail</span>
                                            </div>
                                            @if (member.HasCollected)
                                            {
                                                <span class="badge bg-success rounded-pill px-2 small"><i class="bi bi-check-lg"></i> Paid</span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill px-2 small bg-light text-muted border">Waiting</span>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="p-3 text-center text-muted small">No members joined yet</div>
                                }
                            </div>

                            @* --- Action Buttons --- *@
                            <div class="d-flex gap-2">
                                <form asp-action="CloseGroup" asp-controller="Admin" method="post" class="flex-grow-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="groupId" value="@group.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill fw-bold py-2"
                                            onclick="return confirm('Are you sure you want to terminate this cycle?')">
                                        Terminate Cycle
                                    </button>
                                </form>
                                <button class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm"
                                        style="background: var(--brand-blue); border: none;"
                                        data-bs-toggle="modal"
                                        data-bs-target="#addMemberModal"
                                        onclick="setGroupIdForMember(@group.Id)">
                                    <i class="bi bi-person-plus-fill"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-diagram-3 display-1 text-muted opacity-25"></i>
                <p class="mt-3 text-muted">No active Ajo cycles found. Create one to begin.</p>
            </div>
        }
    </div>
</div>

@* --- Modal 1: Initialize New Group --- *@
<div class="modal fade" id="newGroupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-5 shadow-lg">
            <div class="modal-header border-0 p-4 pb-0">
                <h5 class="fw-bold mb-0" style="color: var(--brand-navy);">Initialize Ajo Cycle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="CreateThriftGroup" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="small fw-bold text-muted">Group Identity Name</label>
                        <input type="text" name="GroupName" class="form-control border-0 bg-light py-3 rounded-4" placeholder="e.g. Ogba Market Hub" required />
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-muted">Target Category Amount</label>
                        <select name="CategoryAmount" class="form-select border-0 bg-light py-3 rounded-4" required>
                            <option value="100000">₦100,000</option>
                            <option value="500000">₦500,000</option>
                            <option value="1000000">₦1,000,000</option>
                        </select>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <label class="small fw-bold text-muted">Cycle Term</label>
                            <select name="DurationMonths" class="form-select border-0 bg-light py-3 rounded-4">
                                <option value="10">10 Months</option>
                                <option value="12">12 Months</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="small fw-bold text-muted">Monthly Installment</label>
                            <input type="number" name="MonthlyContribution" class="form-control border-0 bg-light py-3 rounded-4" placeholder="₦10,000" required />
                        </div>
                    </div>
                    <button type="submit" class="btn login-btn w-100 rounded-pill py-3 fw-bold shadow">Deploy Engine Cycle</button>
                </form>
            </div>
        </div>
    </div>
</div>

@* --- Modal 2: Add Member to Group --- *@
<div class="modal fade" id="addMemberModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-5 shadow-lg">
            <div class="modal-header border-0 p-4 pb-0">
                <h5 class="fw-bold mb-0" style="color: var(--brand-navy);">Add Member to Cycle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="AddMemberToGroup" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ThriftGroupId" id="modalGroupId" />
                    
                    <div class="mb-3">
                        <label class="small fw-bold text-muted">Member Email</label>
                        <input type="email" name="UserEmail" class="form-control border-0 bg-light py-3 rounded-4" placeholder="search user email..." required />
                    </div>
                    
                    <div class="mb-4">
                        <label class="small fw-bold text-muted">Payout Slot (Order)</label>
                        <input type="number" name="PayoutOrder" class="form-control border-0 bg-light py-3 rounded-4" placeholder="e.g. 1" required />
                    </div>

                    <button type="submit" class="btn login-btn w-100 rounded-pill py-3 fw-bold shadow">
                        Confirm Member Slot
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Logic to pass the specific Group ID to the Add Member Modal
    function setGroupIdForMember(id) {
        document.getElementById('modalGroupId').value = id;
    }

    // Modal Initializer Fallback
    document.addEventListener("DOMContentLoaded", function() {
        var groupModal = new bootstrap.Modal(document.getElementById('newGroupModal'));
        var memberModal = new bootstrap.Modal(document.getElementById('addMemberModal'));
    });
</script>
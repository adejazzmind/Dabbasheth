@model Dabbasheth.Models.AdminDashboardViewModel
@{ Layout = "_Layout"; }

@* 🚀 DASHBOARD CONTENT AREA *@
<div class="container-fluid p-4 animate__animated animate__fadeIn">
    
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-4 py-3 rounded-4 shadow-sm mb-4">
        <h5 class="fw-bold mb-0 text-dark">Executive Command Center</h5>
        <div class="ms-auto d-flex align-items-center gap-3">
            <span class="badge bg-soft-success text-success rounded-pill px-3 py-2 border">
                <i class="bi bi-dot animate-pulse"></i> System Live
            </span>
            <div class="vr mx-2"></div>
            <div class="text-end d-none d-md-block">
                <small class="text-muted d-block" style="font-size: 0.7rem;">Administrator</small>
                <span class="fw-bold small">@TempData.Peek("UserName")</span>
            </div>
        </div>
    </nav>

    <div class="row g-4 mb-4">
        @* --- PRIMARY LIQUIDITY PANEL --- *@
        <div class="col-lg-8">
            <div class="premium-card p-5 text-white shadow-lg h-100" style="background: linear-gradient(135deg, #014134 0%, #001f1a 100%); border-radius: 35px;">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <small class="text-uppercase fw-bold opacity-75" style="letter-spacing: 2px; color: #D4AF37;">Total System Liquidity</small>
                        <h1 class="display-3 fw-bold mt-2 mb-0">₦@Model.TotalSystemBalance.ToString("N2")</h1>
                        <div class="mt-4">
                            <span class="badge bg-white bg-opacity-10 rounded-pill px-4 py-2 border border-white border-opacity-25 small">
                                <i class="bi bi-safe2 me-2"></i> Global Wallet & Thrift Pool
                            </span>
                        </div>
                    </div>
                    <div class="icon-box bg-white bg-opacity-10 rounded-4" style="width: 60px; height: 60px;">
                        <i class="bi bi-graph-up-arrow h3 mb-0" style="color: #D4AF37;"></i>
                    </div>
                </div>
            </div>
        </div>

        @* --- USER ANALYTICS PANEL --- *@
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-5 p-4 bg-white h-100 d-flex flex-column justify-content-center text-center">
                <div class="icon-box bg-soft-primary mx-auto mb-3" style="width:70px; height:70px; font-size: 2rem;">
                    <i class="bi bi-people-fill text-primary"></i>
                </div>
                <h2 class="fw-bold mb-0">@Model.TotalUsers</h2>
                <p class="text-muted small">Total Registered Members</p>
                <div class="mt-2 text-success small fw-bold">
                    <i class="bi bi-plus-circle-fill me-1"></i> @Model.NewUsersCount joined today
                </div>
            </div>
        </div>
    </div>

    @* --- STATUS TRACKERS --- *@
    <div class="row g-4 mb-4">
        <div class="col-6 col-md-3">
            <a href="/Admin/SupportCenter" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100 border-start border-5 border-primary card-hover">
                    <small class="text-muted d-block mb-1 text-uppercase fw-bold" style="font-size: 0.65rem;">Support Desk</small>
                    <div class="d-flex align-items-center">
                        <h4 class="fw-bold mb-0">@Model.PendingSupportCount</h4>
                        @if(Model.PendingSupportCount > 0) { <span class="badge bg-danger ms-2 pulse-red">Pending</span> }
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/Admin/RiskControl" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100 border-start border-5 border-danger card-hover">
                    <small class="text-muted d-block mb-1 text-uppercase fw-bold" style="font-size: 0.65rem;">Flagged Risk</small>
                    <div class="d-flex align-items-center">
                        <h4 class="fw-bold mb-0">@Model.FlaggedTransactionCount</h4>
                        @if(Model.FlaggedTransactionCount > 0) { <span class="badge bg-warning text-dark ms-2">Alert</span> }
                    </div>
                </div>
            </a>
        </div>
    </div>

    @* --- CORE SERVICES SHORTCUTS --- *@
    <div class="card border-0 shadow-sm rounded-5 p-4 bg-white mb-4">
        <h6 class="fw-bold text-dark mb-4 px-2">Operational Controls</h6>
        <div class="row text-center g-3">
            <div class="col-4 col-md-2"><div class="op-box bg-soft-primary mx-auto mb-2"><i class="bi bi-bank text-primary"></i></div><small class="fw-bold">Bank</small></div>
            <div class="col-4 col-md-2"><a href="/Admin/PayoutControl" class="text-decoration-none text-dark"><div class="op-box bg-soft-warning mx-auto mb-2"><i class="bi bi-box-arrow-up-right text-warning"></i></div><small class="fw-bold">Payouts</small></a></div>
            <div class="col-4 col-md-2"><a href="/Admin/AjoManagement" class="text-decoration-none text-dark"><div class="op-box bg-soft-danger mx-auto mb-2"><i class="bi bi-piggy-bank text-danger"></i></div><small class="fw-bold">Thrift</small></a></div>
            <div class="col-4 col-md-2"><div class="op-box bg-soft-info mx-auto mb-2"><i class="bi bi-wifi text-info"></i></div><small class="fw-bold">Data</small></div>
            <div class="col-4 col-md-2"><div class="op-box bg-soft-success mx-auto mb-2"><i class="bi bi-phone text-success"></i></div><small class="fw-bold">Airtime</small></div>
            <div class="col-4 col-md-2"><a href="/Admin/Settings" class="text-decoration-none text-dark"><div class="op-box bg-light mx-auto mb-2"><i class="bi bi-gear-fill"></i></div><small class="fw-bold">Platform</small></a></div>
        </div>
    </div>

    @* --- QUEUES --- *@
    <div class="row g-4">
        @* PENDING TRANSACTIONS *@
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-5 bg-white h-100">
                <div class="card-header bg-white p-4 border-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0">Disbursement Queue</h6>
                    <a href="/Admin/PayoutControl" class="text-primary text-decoration-none fw-bold small">Manage All</a>
                </div>
                <div class="px-4 pb-4">
                    @if (Model.PendingTransactions.Any()) {
                        @foreach (var tx in Model.PendingTransactions.Take(3)) {
                            <div class="d-flex align-items-center justify-content-between p-3 border rounded-4 mb-2 bg-light bg-opacity-50">
                                <div>
                                    <p class="fw-bold mb-0 small">@tx.UserEmail.Split('@')[0]</p>
                                    @* ✅ FIXED: Using .Id instead of .Reference *@
                                    <small class="text-muted">TX-ID: #@tx.Id</small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-danger mb-1">₦@tx.Amount.ToString("N0")</div>
                                    <a href="/Admin/PayoutControl" class="btn btn-success btn-xs rounded-pill px-3 shadow-sm">View</a>
                                </div>
                            </div>
                        }
                    } else {
                        <div class="text-center py-5 text-muted small">No pending requests.</div>
                    }
                </div>
            </div>
        </div>

        @* AJO GROUPS *@
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-5 bg-white h-100">
                <div class="card-header bg-white p-4 border-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0">Active Ajo Cycles</h6>
                    <button class="btn btn-dark btn-xs rounded-pill px-3 shadow-sm" onclick="openNewGroupModal()">+ New Cycle</button>
                </div>
                <div class="px-4 pb-4">
                    @if (Model.AllThriftGroups.Any()) {
                        @foreach(var group in Model.AllThriftGroups.Take(3)) {
                            <div class="p-3 border rounded-4 mb-2 bg-white shadow-sm border-start border-5 border-success card-hover">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="badge bg-soft-gold text-gold rounded-pill px-2 small mb-1">₦@group.CategoryAmount.ToString("N0")</span>
                                        <div class="fw-bold small">@group.GroupName</div>
                                    </div>
                                    <a href="/Admin/AjoManagement" class="btn btn-outline-dark btn-xs rounded-pill px-3">Manage</a>
                                </div>
                            </div>
                        }
                    } else {
                        <div class="text-center py-5 text-muted small">No active cycles created.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@* --- 📦 MODAL: NEW GROUP --- *@
<div class="modal fade" id="newGroupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-5 shadow-lg">
            <div class="modal-header border-0 p-4 pb-0">
                <h5 class="fw-bold mb-0">Initialize New Ajo Cycle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="CreateThriftGroup" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="small fw-bold mb-1">Group Name</label>
                        <input type="text" name="GroupName" class="form-control bg-light border-0 py-2" placeholder="e.g. Platinum Hub A" required />
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold mb-1">Contribution Tier</label>
                        <input type="number" name="CategoryAmount" class="form-control bg-light border-0 py-2" placeholder="Amount per member" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow">Initialize Engine</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function openNewGroupModal() { new bootstrap.Modal(document.getElementById('newGroupModal')).show(); }
</script>

<style>
    .card-hover { transition: all 0.3s; cursor: pointer; }
    .card-hover:hover { transform: translateY(-3px); box-shadow: 0 8px 15px rgba(0,0,0,0.05) !important; }
    .rounded-5 { border-radius: 2rem !important; }
    .rounded-4 { border-radius: 1.25rem !important; }
    .bg-soft-primary { background: rgba(13, 110, 253, 0.08); }
    .bg-soft-success { background: rgba(25, 135, 84, 0.08); }
    .bg-soft-danger { background: rgba(220, 53, 69, 0.08); }
    .bg-soft-warning { background: rgba(255, 193, 7, 0.08); }
    .bg-soft-info { background: rgba(13, 202, 240, 0.08); }
    .bg-soft-gold { background: rgba(212, 175, 55, 0.1); }
    .text-gold { color: #D4AF37 !important; }
    .icon-box, .op-box { width: 50px; height: 50px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; }
    .op-box { transition: 0.2s; cursor: pointer; }
    .op-box:hover { transform: scale(1.1); filter: brightness(0.95); }
    .btn-xs { padding: 0.3rem 0.8rem; font-size: 0.7rem; font-weight: bold; text-transform: uppercase; }
    .animate-pulse { animation: pulse 2s infinite; }
    @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
    .pulse-red { animation: pulse-red-key 2s infinite; }
    @@keyframes pulse-red-key { 0% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.4); } 70% { box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); } 100% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); } }
</style>
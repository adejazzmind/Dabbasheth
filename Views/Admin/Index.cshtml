@model Dabbasheth.Models.AdminDashboardViewModel
@{ Layout = "_Layout"; ViewData["Title"] = "Executive Dashboard"; }
<style>
.px-page{padding:28px 32px}
.stat-hero{background:linear-gradient(135deg,#0A0F1E 0%,#1a2744 50%,#0A0F1E 100%);border-radius:24px;padding:36px;color:#fff;position:relative;overflow:hidden}
.stat-hero::before{content:'';position:absolute;top:-60px;right:-60px;width:220px;height:220px;border-radius:50%;background:radial-gradient(circle,rgba(26,115,232,.35) 0%,transparent 70%)}
.stat-hero::after{content:'';position:absolute;bottom:-40px;left:30%;width:180px;height:180px;border-radius:50%;background:radial-gradient(circle,rgba(14,165,233,.2) 0%,transparent 70%)}
.balance-amount{font-size:clamp(1.8rem,4vw,3rem);font-weight:900;letter-spacing:-1px;position:relative;z-index:1}
.kpi-card{background:#fff;border-radius:20px;padding:22px;border:1px solid #F1F5F9;transition:.25s;cursor:default}
.kpi-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.08)}
.kpi-icon{width:52px;height:52px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;margin-bottom:12px}
.kpi-num{font-size:1.8rem;font-weight:800;color:#0A0F1E;line-height:1}
.kpi-label{font-size:.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:.8px;margin-top:4px}
.section-card{background:#fff;border-radius:20px;border:1px solid #F1F5F9;overflow:hidden}
.section-header{padding:20px 24px;border-bottom:1px solid #F8FAFC;display:flex;justify-content:space-between;align-items:center}
.section-header h6{font-weight:700;font-size:.85rem;text-transform:uppercase;letter-spacing:.8px;color:#374151;margin:0}
.op-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;padding:20px 24px}
.op-btn{display:flex;flex-direction:column;align-items:center;gap:8px;text-decoration:none;border-radius:16px;padding:16px 8px;transition:.2s;border:1px solid #F1F5F9;background:#FAFAFA}
.op-btn:hover{background:#EFF6FF;border-color:#BFDBFE;transform:translateY(-3px)}
.op-btn .ic{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.2rem}
.op-btn span{font-size:.72rem;font-weight:600;color:#374151}
.tx-row{display:flex;align-items:center;justify-content:space-between;padding:14px 24px;border-bottom:1px solid #F8FAFC;transition:.15s}
.tx-row:last-child{border-bottom:none}
.tx-row:hover{background:#F8FAFC}
.ajo-row{display:flex;align-items:center;justify-content:space-between;padding:14px 24px;border-bottom:1px solid #F8FAFC}
.ajo-row:last-child{border-bottom:none}
.badge-pill{font-size:.7rem;font-weight:600;padding:4px 10px;border-radius:99px}
@@media(max-width:768px){.px-page{padding:16px}.op-grid{grid-template-columns:repeat(3,1fr)}.balance-amount{font-size:2rem}}
</style>

<div class="px-page">

    @* ── HERO ROW ── *@
    <div class="row g-3 mb-4">
        <div class="col-lg-7">
            <div class="stat-hero h-100">
                <p style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;opacity:.6;margin-bottom:8px;position:relative;z-index:1">Total System Liquidity</p>
                <div class="balance-amount">₦@Model.TotalSystemBalance.ToString("N2")</div>
                <div style="margin-top:20px;position:relative;z-index:1">
                    <span style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:99px;padding:6px 16px;font-size:.75rem;font-weight:600">
                        <i class="bi bi-safe2 me-2" style="color:#F59E0B"></i>Global Wallet &amp; Thrift Pool
                    </span>
                </div>
                @* Decorative SVG graph *@
                <svg style="position:absolute;bottom:20px;right:24px;width:140px;opacity:.3" viewBox="0 0 140 50">
                    <polyline points="0,45 20,30 40,38 60,15 80,20 110,8 140,2" fill="none" stroke="#0EA5E9" stroke-width="2.5" stroke-linecap="round"/>
                    <polyline points="0,45 20,30 40,38 60,15 80,20 110,8 140,2" fill="url(#g)" stroke="none"/>
                    <defs><linearGradient id="g" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#0EA5E9" stop-opacity=".3"/><stop offset="100%" stop-color="#0EA5E9" stop-opacity="0"/></linearGradient></defs>
                </svg>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="row g-3 h-100">
                <div class="col-6">
                    <div class="kpi-card h-100">
                        <div class="kpi-icon" style="background:#EFF6FF"><i class="bi bi-people-fill" style="color:#1A73E8"></i></div>
                        <div class="kpi-num">@Model.TotalUsers</div>
                        <div class="kpi-label">Members</div>
                        <div style="font-size:.72rem;color:#10B981;font-weight:600;margin-top:6px">+@Model.NewUsersCount today</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="kpi-card h-100">
                        <div class="kpi-icon" style="background:#FEF2F2"><i class="bi bi-exclamation-triangle-fill" style="color:#EF4444"></i></div>
                        <div class="kpi-num">@Model.FlaggedTransactionCount</div>
                        <div class="kpi-label">Flagged Txns</div>
                        @if (Model.FlaggedTransactionCount > 0) { <div style="font-size:.7rem;color:#EF4444;font-weight:700;margin-top:6px">⚠ Needs attention</div> }
                    </div>
                </div>
                <div class="col-6">
                    <div class="kpi-card h-100">
                        <div class="kpi-icon" style="background:#ECFDF5"><i class="bi bi-headset" style="color:#10B981"></i></div>
                        <div class="kpi-num">@Model.PendingSupportCount</div>
                        <div class="kpi-label">Open Tickets</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="kpi-card h-100">
                        <div class="kpi-icon" style="background:#FFF7ED"><i class="bi bi-diagram-3-fill" style="color:#F59E0B"></i></div>
                        <div class="kpi-num">@Model.AllThriftGroups.Count</div>
                        <div class="kpi-label">Ajo Cycles</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── OPERATIONAL HUB ── *@
    <div class="section-card mb-4">
        <div class="section-header"><h6>Operational Controls</h6></div>
        <div class="op-grid">
            @foreach(var op in new[]{
                new{Icon="bi-people-fill",      Label="Customers",  Url="/Admin/UserManagement", Bg="#EFF6FF",  Color="#1A73E8"},
                new{Icon="bi-wallet2",          Label="Payouts",    Url="/Admin/PayoutControl",  Bg="#ECFDF5",  Color="#10B981"},
                new{Icon="bi-cash-coin",        Label="Wallets",    Url="/Admin/WalletControl",  Bg="#FFF7ED",  Color="#F59E0B"},
                new{Icon="bi-diagram-3-fill",   Label="Ajo Engine", Url="/Admin/AjoManagement",  Bg="#F5F3FF",  Color="#8B5CF6"},
                new{Icon="bi-shield-exclamation",Label="Risk",      Url="/Admin/RiskControl",    Bg="#FEF2F2",  Color="#EF4444"},
                new{Icon="bi-gear-fill",        Label="Settings",   Url="/Admin/Settings",       Bg="#F1F5F9",  Color="#64748B"}
            }){
                <a href="@op.Url" class="op-btn">
                    <div class="ic" style="background:@op.Bg"><i class="bi @op.Icon" style="color:@op.Color"></i></div>
                    <span>@op.Label</span>
                </a>
            }
        </div>
    </div>

    @* ── QUEUES ── *@
    <div class="row g-3">
        <div class="col-lg-6">
            <div class="section-card">
                <div class="section-header">
                    <h6>Disbursement Queue</h6>
                    <a href="/Admin/PayoutControl" style="font-size:.8rem;color:#1A73E8;font-weight:600;text-decoration:none">Manage All</a>
                </div>
                @if (Model.PendingTransactions.Any()){
                    @foreach(var tx in Model.PendingTransactions.Take(3)){
                        <div class="tx-row">
                            <div style="display:flex;align-items:center;gap:12px">
                                <div style="width:38px;height:38px;background:#FEF2F2;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                    <i class="bi bi-arrow-up-right" style="color:#EF4444;font-size:.9rem"></i>
                                </div>
                                <div>
                                    <div style="font-weight:600;font-size:.85rem;color:#0F172A">@tx.UserEmail.Split('@')[0]</div>
                                    <div style="font-size:.72rem;color:#94A3B8">#TX-@tx.Id · @tx.Date.ToString("dd MMM")</div>
                                </div>
                            </div>
                            <div style="text-align:right">
                                <div style="font-weight:700;font-size:.9rem;color:#EF4444">₦@tx.Amount.ToString("N0")</div>
                                <span class="badge-pill" style="background:#FEF2F2;color:#EF4444">PENDING</span>
                            </div>
                        </div>
                    }
                } else {
                    <div style="padding:40px;text-align:center;color:#CBD5E1">
                        <i class="bi bi-check-circle" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        <span style="font-size:.85rem">No pending withdrawals</span>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-6">
            <div class="section-card">
                <div class="section-header">
                    <h6>Active Ajo Cycles</h6>
                    <a href="/Admin/AjoManagement" style="font-size:.8rem;color:#1A73E8;font-weight:600;text-decoration:none">View All</a>
                </div>
                @if(Model.AllThriftGroups.Any()){
                    @foreach(var g in Model.AllThriftGroups.Take(3)){
                        <div class="ajo-row">
                            <div style="display:flex;align-items:center;gap:12px">
                                <div style="width:38px;height:38px;background:#F5F3FF;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                    <i class="bi bi-diagram-3-fill" style="color:#8B5CF6;font-size:.9rem"></i>
                                </div>
                                <div>
                                    <div style="font-weight:600;font-size:.85rem;color:#0F172A">@g.GroupName</div>
                                    <div style="font-size:.72rem;color:#94A3B8">@(g.MemberPlans?.Count??0) members · @g.Status</div>
                                </div>
                            </div>
                            <span class="badge-pill" style="background:#F5F3FF;color:#8B5CF6">₦@g.CategoryAmount.ToString("N0")</span>
                        </div>
                    }
                } else {
                    <div style="padding:40px;text-align:center;color:#CBD5E1">
                        <i class="bi bi-diagram-3" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        <span style="font-size:.85rem">No active cycles</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@model IEnumerable<Dabbasheth.Models.SystemSetting>
@{
    Layout = "_Layout";
}

<div class="container-fluid py-4 bg-light min-vh-100 px-lg-4">
    <div class="mb-4 px-2">
        <h4 class="fw-bold mb-0 text-dark"><i class="bi bi-gear-wide-connected me-2"></i>Global Revenue Settings</h4>
        <p class="text-muted small">Configure transaction fees and service charges</p>
    </div>

    <div class="row g-3">
        @foreach (var fee in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="icon-box bg-soft-gold text-gold rounded-3" style="width:45px; height:45px;">
                            <i class="bi bi-cash-coin h4 mb-0"></i>
                        </div>
                        <span class="badge bg-light text-dark rounded-pill border">Live</span>
                    </div>
                    
                    <h6 class="fw-bold mb-1">@fee.SettingKey</h6>
                    <p class="text-muted small mb-3">@fee.Description</p>
                    
                    <form asp-action="UpdateFee" method="post" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="key" value="@fee.SettingKey" />
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-0">₦</span>
                            <input type="number" name="value" class="form-control bg-light border-0 fw-bold" value="@fee.SettingValue">
                        </div>
                        <button type="submit" class="btn btn-dark btn-sm rounded-3 px-3">Save</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
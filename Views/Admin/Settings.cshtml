@model IEnumerable<Dabbasheth.Models.SystemSetting>
@{
    Layout = "_Layout"; ViewData["Title"] = "Platform Settings";
}

<div class="container-fluid p-4">
    <div class="mb-4">
        <h4 class="fw-bold mb-1"><i class="bi bi-gear-wide-connected me-2"></i>Revenue Settings</h4>
        <p class="text-muted small">Configure platform fees and service charges.</p>
    </div>

    <div class="row g-3">
        @foreach (var fee in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="icon-box" style="background:#fff3e0;width:45px;height:45px;">
                            <i class="bi bi-cash-coin" style="color:#e65100;font-size:1.2rem;"></i>
                        </div>
                        <span class="badge bg-success rounded-pill px-2">Live</span>
                    </div>
                    <h6 class="fw-bold mb-1">@fee.SettingKey</h6>
                    <p class="text-muted small mb-3">@fee.Description</p>
                    <form asp-action="UpdateFee" method="post" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="key" value="@fee.SettingKey" />
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-0 fw-bold">₦</span>
                            <input type="number" name="value" class="form-control bg-light border-0 fw-bold"
                                   value="@fee.SettingValue" step="0.01" />
                        </div>
                        <button type="submit" class="btn btn-dark btn-sm rounded-3 px-3 fw-bold">Save</button>
                    </form>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 text-muted">
                <i class="bi bi-sliders display-1 opacity-25 d-block mb-3"></i>
                No settings configured yet.
            </div>
        }
    </div>
</div>

@model Dabbasheth.Models.UserDashboardViewModel
@{
    Layout = "_Layout";
}

<div class="login-bg animate__animated animate__fadeIn">
    <div class="card login-card animate__animated animate__fadeInDown"
         style="width: 100%; max-width: 420px; border: none;">
        
        <div class="card-body p-5">
            <div class="text-center mb-4">
                @* 🔵 PLATINUM NAVY ICON BOX *@
                <div class="icon-box mx-auto mb-3" style="width: 70px; height: 70px; background: var(--brand-navy); border-radius: 20px; display: flex; align-items: center; justify-content: center; border: 2px solid var(--brand-sky);">
                    <i class="bi bi-shield-lock-fill h2 mb-0" style="color: var(--brand-sky);"></i>
                </div>
                <h3 class="fw-bold" style="color: var(--brand-navy); letter-spacing: -1px;">IES URBAN HUB</h3>
                <p class="text-muted small text-uppercase fw-bold" style="letter-spacing: 1px;">Executive Terminal</p>
            </div>

            @* 🛑 ERROR MESSAGE AREA *@
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger border-0 rounded-4 small py-2 mb-4 animate__animated animate__shakeX">
                    <i class="bi bi-exclamation-circle me-2"></i> @TempData["Error"]
                </div>
            }

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                @* 📧 EMAIL INPUT *@
                <div class="mb-3">
                    <label class="small fw-bold text-muted ms-1 mb-1">Corporate Email</label>
                    <div class="input-group">
                        <span class="input-group-text border-0 bg-light rounded-start-4 ps-3">
                            <i class="bi bi-envelope text-muted"></i>
                        </span>
                        <input type="email" name="email" class="form-control border-0 bg-light py-3 pe-4 rounded-end-4 shadow-none"
                               placeholder="admin@ieshub.com" required />
                    </div>
                </div>

                @* 🔑 PASSWORD INPUT *@
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="small fw-bold text-muted ms-1">Security Key</label>
                        <a href="#" class="text-decoration-none small fw-bold" style="color: var(--brand-blue); font-size: 0.7rem;">Forgot?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text border-0 bg-light rounded-start-4 ps-3">
                            <i class="bi bi-key text-muted"></i>
                        </span>
                        <input type="password" name="password" class="form-control border-0 bg-light py-3 pe-4 rounded-end-4 shadow-none"
                               placeholder="••••••••" required />
                    </div>
                </div>

                @* 🔵 AUTHORIZE SESSION BUTTON (SKY BLUE GRADIENT) *@
                <button type="submit" class="btn login-btn w-100 py-3 rounded-pill fw-bold shadow-lg mb-4 text-uppercase">
                    Authorize Session
                </button>
                
                <div class="text-center">
                    <p class="small text-muted mb-0">Secure Gateway Powered by <span class="fw-bold" style="color: var(--brand-navy);">Dabbasheth v6.0</span></p>
                    <a href="/Account/Register" class="text-decoration-none small fw-bold mt-2 d-inline-block" style="color: var(--brand-blue);">Create New Identity</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* --- Clean Overrides for Platinum Look --- */
    .login-bg {
        background: radial-gradient(circle at top right, var(--brand-blue) 0%, var(--brand-navy) 60%) !important;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .form-control:focus {
        background-color: #f0f4f8 !important; /* Soft blue tint instead of green */
        border: 1px solid var(--brand-sky) !important;
    }

    .login-btn:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
    }
</style>
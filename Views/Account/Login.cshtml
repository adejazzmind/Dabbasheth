@{
    Layout = null;
    ViewData["Title"] = "Login – IES Urban Hub";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
            *, *::before, *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            html, body {
                width: 100%;
                min-height: 100%;
            }

            body {
                min-height: 100vh;
                background: radial-gradient(ellipse at 70% 20%, #1e40af 0%, #0A0F1E 60%);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
                font-family: 'Inter', 'Segoe UI', sans-serif;
            }

            .auth-card {
                background: #fff;
                border-radius: 28px;
                padding: 44px 40px;
                width: 100%;
                max-width: 420px;
                box-shadow: 0 40px 80px rgba(0, 0, 0, .35);
            }

            .auth-logo {
                width: 64px;
                height: 64px;
                background: linear-gradient(135deg, #0A0F1E, #1A73E8);
                border-radius: 18px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px;
            }

                .auth-logo i {
                    color: #F59E0B;
                    font-size: 1.6rem;
                }

            h3 {
                font-weight: 800;
                text-align: center;
                color: #0A0F1E;
                margin: 0 0 4px;
                font-size: 1.3rem;
                letter-spacing: 1px;
            }

            .portal-label {
                text-align: center;
                color: #64748B;
                font-size: .8rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                margin-bottom: 28px;
            }

            .auth-input {
                border: 1.5px solid #E2E8F0;
                border-radius: 14px;
                padding: 14px 16px;
                font-size: .9rem;
                width: 100%;
                outline: none;
                transition: .2s;
                background: #F8FAFC;
                font-family: 'Inter', 'Segoe UI', sans-serif;
            }

                .auth-input:focus {
                    border-color: #1A73E8;
                    background: #fff;
                    box-shadow: 0 0 0 3px rgba(26, 115, 232, .1);
                }

            .auth-btn {
                background: linear-gradient(135deg, #1A73E8, #0EA5E9);
                color: #fff;
                border: none;
                border-radius: 14px;
                padding: 15px;
                font-size: .95rem;
                font-weight: 700;
                width: 100%;
                cursor: pointer;
                transition: .3s;
                font-family: 'Inter', 'Segoe UI', sans-serif;
                letter-spacing: .2px;
            }

                .auth-btn:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 12px 30px rgba(26, 115, 232, .35);
                }

            .pw-wrap {
                position: relative;
            }

                .pw-wrap .auth-input {
                    padding-right: 48px;
                }

            .pw-eye {
                position: absolute;
                right: 16px;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                cursor: pointer;
                color: #94A3B8;
                font-size: 1.1rem;
                padding: 0;
                transition: .2s;
            }

                .pw-eye:hover {
                    color: #1A73E8;
                }

            .divider {
                border: none;
                border-top: 1px solid #F1F5F9;
                margin: 24px 0;
            }

            .error-box {
                background: #FEF2F2;
                border: 1px solid #FECACA;
                color: #991B1B;
                border-radius: 12px;
                padding: 12px 16px;
                font-size: .85rem;
                margin-bottom: 20px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .success-box {
                background: #ECFDF5;
                border: 1px solid #A7F3D0;
                color: #065F46;
                border-radius: 12px;
                padding: 12px 16px;
                font-size: .85rem;
                margin-bottom: 20px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .field-label {
                font-size: .8rem;
                font-weight: 600;
                color: #374151;
                display: block;
                margin-bottom: 6px;
            }

            @@media (max-width: 480px) {
                .auth-card {
                    padding: 32px 24px;
                    border-radius: 24px;
                }
            }
    </style>
</head>
<body>

    <div class="auth-card animate__animated animate__fadeInUp">

        <div class="auth-logo">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <h3>IES URBAN HUB</h3>
        <p class="portal-label">Secure Access Portal</p>

        @if (TempData["Error"] != null)
        {
            <div class="error-box">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @TempData["Error"]
            </div>
        }
        @if (TempData["Message"] != null)
        {
            <div class="success-box">
                <i class="bi bi-check-circle-fill"></i>
                @TempData["Message"]
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div style="margin-bottom:16px">
                <label class="field-label">Email Address</label>
                <input type="email" name="email" class="auth-input"
                       placeholder="you@example.com"
                       required autocomplete="email" />
            </div>

            <div style="margin-bottom:24px">
                <label class="field-label">Password</label>
                <div class="pw-wrap">
                    <input type="password" name="password" id="pw"
                           class="auth-input" placeholder="••••••••"
                           required autocomplete="current-password" />
                    <button type="button" class="pw-eye"
                            onclick="togglePw('pw','eyeIcon1')"
                            aria-label="Show password">
                        <i class="bi bi-eye" id="eyeIcon1"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="auth-btn">Authorize Access</button>
        </form>

        <hr class="divider" />

        <p style="text-align:center;font-size:.85rem;color:#64748B;margin:0">
            No account?
            <a asp-action="Register"
                   style="color:#1A73E8;font-weight:700;text-decoration:none;">
                Create Wallet
            </a>
        </p>

    </div>

    <script>
            function togglePw(id, iconId) {
                const i = document.getElementById(id);
                const ic = document.getElementById(iconId);
                if (i.type === 'password') {
                    i.type = 'text';
                    ic.className = 'bi bi-eye-slash';
                } else {
                    i.type = 'password';
                    ic.className = 'bi bi-eye';
                }
            }
    </script>

</body>
</html>
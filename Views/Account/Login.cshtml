@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="card border-0 shadow-lg p-4 p-md-5" style="width: 100%; max-width: 500px; border-radius: 30px;">
        
        <div class="text-center mb-4">
            <div class="bg-soft-primary d-inline-block p-3 rounded-circle mb-3">
                <i class="bi bi-shield-lock-fill text-primary h2 mb-0"></i>
            </div>
            <h2 class="fw-bold text-dark">Welcome Back</h2>
            <p class="text-muted small">Sign in to **IES Life Hub (Dabbasheth)**</p>
        </div>

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="form-label small fw-bold text-muted">EMAIL ADDRESS</label>
                <input type="email" name="email" class="form-control form-control-lg bg-light border-0"
                       placeholder="adejazzmind@gmail.com" required style="border-radius: 15px;" />
            </div>

            <div class="mb-4 position-relative">
                <div class="d-flex justify-content-between">
                    <label class="form-label small fw-bold text-muted">PASSWORD</label>
                    <a href="#" class="text-decoration-none small fw-bold">Forgot?</a>
                </div>
                
                @* PASSWORD EYE INTEGRATION *@
                <div class="input-group">
                    <input type="password" name="password" id="loginPassword" class="form-control form-control-lg bg-light border-0"
                           placeholder="••••••••" required style="border-radius: 15px 0 0 15px;" />
                    <span class="input-group-text bg-light border-0" style="border-radius: 0 15px 15px 0; cursor: pointer;" onclick="togglePasswordVisibility()">
                        <i class="bi bi-eye-slash text-muted" id="eyeIcon"></i>
                    </span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold py-3 shadow">
                Login to Wallet
            </button>
        </form>

        <div class="text-center mt-4">
            <p class="small text-muted">New to Dabbasheth? <a asp-action="Register" class="fw-bold text-decoration-none">Create Account</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePasswordVisibility() {
            const passwordField = document.getElementById("loginPassword");
            const eyeIcon = document.getElementById("eyeIcon");
            
            if (passwordField.type === "password") {
                passwordField.type = "text";
                eyeIcon.classList.replace("bi-eye-slash", "bi-eye");
            } else {
                passwordField.type = "password";
                eyeIcon.classList.replace("bi-eye", "bi-eye-slash");
            }
        }
    </script>
}